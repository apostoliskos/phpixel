{
	"version": 3,
	"routes": [
		{
			"src": "^/ecommerce$",
			"headers": {
				"Location": "/kataskevi-eshop"
			},
			"status": 301
		},
		{
			"src": "^/hosting$",
			"headers": {
				"Location": "/services"
			},
			"status": 301
		},
		{
			"src": "^/istoselides-landingpage$",
			"headers": {
				"Location": "/kataskevi-istoselidon"
			},
			"status": 301
		},
		{
			"src": "^/social-media-marketing$",
			"headers": {
				"Location": "/diafimisi"
			},
			"status": 301
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/contact/?$",
			"dest": "_render"
		},
		{
			"src": "^/blog/posts/ab/?$",
			"dest": "_render"
		},
		{
			"src": "^/blog/posts/ux-ui/?$",
			"dest": "_render"
		},
		{
			"src": "^/blog/tags/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/blog/tags/?$",
			"dest": "_render"
		},
		{
			"src": "^/fail/?$",
			"dest": "_render"
		},
		{
			"src": "^/success/?$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}