---
import BaseLayout from './BaseLayout.astro';
import { generateTagData } from '../utils/helpers';

const { content: { title, description, publishDate, canonicalURL, featuredImage, tags } } = Astro.props;

let allTagsData = [];
if (tags && tags.length > 0) {
  allTagsData = generateTagData(tags);
}

const dateStr = publishDate
  ? (() => {
      try {
        return new Date(publishDate).toLocaleDateString('el-GR', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        });
      } catch {
        return publishDate;
      }
    })()
  : null;
---

<BaseLayout
  title={`${title} — Phpixel Blog`}
  description={description}
  image={featuredImage}
  canonicalURL={canonicalURL}
>

  <article class="post">
    <!-- Post Header -->
    <header class="post-header">
      <div class="post-header__bg"></div>
      <div class="container post-header__inner">
        <div class="reveal">
          <a href="/blog" class="post-header__back">&larr; Πίσω στο Blog</a>
          {allTagsData.length > 0 && (
            <div class="post-tags post-tags--header">
              {allTagsData.map((tag) => (
                <a href={`/blog/tags/${tag.slug}`} class="post-tag">{tag.title}</a>
              ))}
            </div>
          )}
          <h1 class="post-header__title">{title}</h1>
          {dateStr && (
            <time class="post-header__date">{dateStr}</time>
          )}
        </div>
      </div>
    </header>

    <!-- Featured Image -->
    {featuredImage && (
      <div class="post-featured container">
        <img src={featuredImage} alt={title} class="post-featured__img reveal" />
      </div>
    )}

    <!-- Post Body -->
    <div class="container post-body">
      <div class="post-content reveal">
        <slot />
      </div>

      <!-- Tags Footer -->
      {allTagsData.length > 0 && (
        <div class="post-tags-footer reveal">
          <span class="post-tags-footer__label">Tags:</span>
          {allTagsData.map((tag, index) => (
            <a href={`/blog/tags/${tag.slug}`} class="post-tag">
              {tag.title}
            </a>
          ))}
        </div>
      )}
    </div>
  </article>

</BaseLayout>

<style is:global>
  /* Post Header */
  .post-header {
    position: relative;
    padding: calc(var(--navbar-height) + 3rem) 0 2rem;
  }

  .post-header__bg {
    position: absolute;
    inset: 0;
    background: var(--gradient-subtle);
  }

  .post-header__inner {
    position: relative;
  }

  .post-header__back {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 600;
    opacity: 0.6;
    margin-bottom: 1.5rem;
    transition: var(--theme-transition);
  }

  .post-header__back:hover {
    opacity: 1;
    color: var(--accent-blue);
  }

  .post-header__title {
    max-width: 800px;
    margin-bottom: 1rem;
  }

  .post-header__date {
    display: block;
    font-size: 0.9rem;
    opacity: 0.5;
    font-weight: 500;
  }

  /* Tags */
  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1rem;
  }

  .post-tag {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: 1px solid rgba(0, 0, 0, 0.12);
    border-radius: 2rem;
    transition: var(--theme-transition);
    text-decoration: none;
    color: inherit;
  }

  .post-tag:hover {
    border-color: var(--accent-blue);
    color: var(--accent-blue);
  }

  /* Featured Image */
  .post-featured {
    margin-top: 2rem;
    margin-bottom: 3rem;
  }

  .post-featured__img {
    width: 100%;
    max-width: 900px;
    margin: 0 auto;
    border-radius: var(--theme-shape-radius);
    object-fit: cover;
  }

  /* Post Body */
  .post-body {
    max-width: 780px;
    margin-left: auto;
    margin-right: auto;
    padding-bottom: var(--section-margin);
  }

  /* Post Content — Article Styling */
  .post-content h2 {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    font-size: 1.6rem;
  }

  .post-content h3 {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    font-size: 1.3rem;
  }

  .post-content p {
    font-size: 1.05rem;
    line-height: 1.85;
    opacity: 0.8;
    margin-bottom: 1.25rem;
  }

  .post-content img {
    border-radius: var(--theme-shape-radius-sm);
    margin: 2rem 0;
  }

  .post-content ul,
  .post-content ol {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .post-content li {
    font-size: 1.05rem;
    line-height: 1.85;
    opacity: 0.8;
    margin-bottom: 0.5rem;
  }

  .post-content blockquote {
    border-left: 3px solid var(--accent-blue);
    padding: 1rem 1.5rem;
    margin: 2rem 0;
    background: var(--theme-surface-1);
    border-radius: 0 var(--theme-shape-radius-sm) var(--theme-shape-radius-sm) 0;
    font-style: italic;
    opacity: 0.85;
  }

  .post-content code {
    background: var(--theme-surface-1);
    padding: 0.15rem 0.4rem;
    border-radius: 0.25rem;
    font-size: 0.9em;
  }

  .post-content pre {
    background: var(--theme-primary);
    color: var(--theme-on-primary);
    padding: 1.25rem 1.5rem;
    border-radius: var(--theme-shape-radius-sm);
    overflow-x: auto;
    margin: 2rem 0;
  }

  .post-content pre code {
    background: transparent;
    padding: 0;
    color: inherit;
  }

  .post-content a {
    color: var(--accent-blue);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .post-content a:hover {
    opacity: 0.8;
  }

  .post-content strong {
    font-weight: 700;
  }

  /* Tags Footer */
  .post-tags-footer {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
  }

  .post-tags-footer__label {
    font-size: 0.85rem;
    font-weight: 600;
    opacity: 0.5;
  }
</style>
