---
import { ViewTransitions } from 'astro:transitions';
import { site } from '../data/site';
import { nav } from '../config/nav.js';
import { footerLists, footerSocials } from '../config/footer';
import { Icon } from 'astro-icon/components';

import '../styles/index.css';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
}

const {
  title = `${site.name} — ${site.tagline}`,
  description = site.description,
  image = '/social.png',
  canonicalURL = new URL(Astro.url.pathname, Astro.site).toString(),
} = Astro.props;

const currentPath = Astro.url.pathname;
---

<html lang={site.lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.site)} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <!-- View Transitions -->
    <ViewTransitions />

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-H58TJPTQM4"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-H58TJPTQM4');
    </script>
  </head>

  <body>
    <!-- ========== NAVBAR (Glassmorphism) ========== -->
    <header class="navbar" id="navbar">
      <div class="navbar__inner">
        <a href="/" class="navbar__logo" transition:name="logo">
          <span class="logo-text">ph<span class="logo-accent">pixel</span></span>
        </a>

        <nav class="navbar__nav" id="main-nav">
          {nav.map((item) => (
            <div class="nav-item">
              <a
                href={item.slug}
                class:list={['nav-link', { active: currentPath === item.slug }]}
              >
                {item.title}
                {item.children && (
                  <Icon name="ic:baseline-keyboard-arrow-down" class="nav-chevron" />
                )}
              </a>
              {item.children && (
                <div class="nav-dropdown">
                  {item.children.map((child) => (
                    <a href={child.slug} class="nav-dropdown__link">
                      {child.title}
                    </a>
                  ))}
                </div>
              )}
            </div>
          ))}
        </nav>

        <div class="navbar__actions">
          <a href="/contact" class="btn btn--primary btn--sm">Επικοινωνία</a>
          <button class="mobile-toggle" id="mobile-toggle" aria-label="Menu">
            <span></span><span></span><span></span>
          </button>
        </div>
      </div>
    </header>

    <!-- Mobile Nav Overlay -->
    <div class="mobile-nav" id="mobile-nav">
      <nav class="mobile-nav__inner">
        {nav.map((item) => (
          <a href={item.slug} class="mobile-nav__link">{item.title}</a>
        ))}
        <a href="/contact" class="btn btn--primary" style="margin-top: 1rem;">Επικοινωνία</a>
      </nav>
    </div>

    <!-- ========== MAIN CONTENT ========== -->
    <main id="content" transition:animate="fade">
      <slot />
    </main>

    <!-- ========== FOOTER ========== -->
    <footer class="footer">
      <div class="footer__inner">
        <div class="footer__brand">
          <span class="logo-text logo-text--footer">ph<span class="logo-accent">pixel</span></span>
          <p class="footer__tagline">{site.tagline}</p>
          <div class="footer__socials">
            {footerSocials.map((social) => (
              <a href={social.url} target="_blank" rel="noopener noreferrer" aria-label={social.name} class="social-link">
                <Icon name={social.icon} />
              </a>
            ))}
          </div>
        </div>

        {footerLists.map((list) => (
          <div class="footer__list">
            <h4>{list.title}</h4>
            <ul>
              {list.items.map((item) => (
                <li><a href={item.slug}>{item.title}</a></li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <div class="footer__bottom">
        <p>&copy; {new Date().getFullYear()} {site.name}. All rights reserved.</p>
      </div>
    </footer>

    <!-- ========== SCRIPTS ========== -->
    <script is:inline>
      // Navbar scroll effect
      const navbar = document.getElementById('navbar');
      let lastScroll = 0;
      window.addEventListener('scroll', () => {
        const scrollY = window.scrollY;
        if (scrollY > 50) {
          navbar.classList.add('navbar--scrolled');
        } else {
          navbar.classList.remove('navbar--scrolled');
        }
        lastScroll = scrollY;
      });

      // Mobile menu toggle
      const toggle = document.getElementById('mobile-toggle');
      const mobileNav = document.getElementById('mobile-nav');
      if (toggle && mobileNav) {
        toggle.addEventListener('click', () => {
          toggle.classList.toggle('is-open');
          mobileNav.classList.toggle('is-open');
          document.body.classList.toggle('no-scroll');
        });
      }
    </script>

    <style is:global>
      /* ========================================
         GLOBAL STYLES
         ======================================== */

      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        scroll-behavior: smooth;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      body {
        font-family: var(--font-body);
        background: var(--theme-bg);
        color: var(--theme-on-bg);
        line-height: 1.7;
        overflow-x: hidden;
      }

      body.no-scroll {
        overflow: hidden;
      }

      h1, h2, h3, h4, h5, h6 {
        font-family: var(--font-heading);
        font-weight: 800;
        line-height: 1.15;
        letter-spacing: -0.02em;
      }

      h1 { font-size: clamp(2.5rem, 5vw, 4rem); }
      h2 { font-size: clamp(1.8rem, 3.5vw, 2.8rem); }
      h3 { font-size: clamp(1.3rem, 2.5vw, 1.8rem); }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        max-width: 100%;
        height: auto;
        display: block;
      }

      .container {
        max-width: var(--container-max-width);
        margin: 0 auto;
        padding: 0 var(--container-padding);
      }

      /* ========================================
         BUTTON SYSTEM
         ======================================== */

      .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.75rem;
        border-radius: var(--button-border-radius);
        font-family: var(--font-body);
        font-weight: 600;
        font-size: 0.95rem;
        cursor: pointer;
        transition: var(--theme-transition);
        border: 2px solid transparent;
        text-decoration: none;
      }

      .btn--primary {
        background: var(--button-color);
        color: var(--button-text);
        border-color: var(--button-color);
      }

      .btn--primary:hover {
        background: var(--button-color-hover);
        border-color: var(--button-color-hover);
        transform: translateY(-2px);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
      }

      .btn--outline {
        background: transparent;
        color: var(--theme-on-bg);
        border-color: var(--theme-on-bg);
      }

      .btn--outline:hover {
        background: var(--theme-on-bg);
        color: var(--theme-bg);
        transform: translateY(-2px);
      }

      .btn--sm {
        padding: 0.5rem 1.25rem;
        font-size: 0.875rem;
      }

      .btn--lg {
        padding: 1rem 2.25rem;
        font-size: 1.05rem;
      }

      /* ========================================
         NAVBAR
         ======================================== */

      .navbar {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 1000;
        height: var(--navbar-height);
        display: flex;
        align-items: center;
        transition: var(--theme-transition);
      }

      .navbar--scrolled {
        background: var(--glass-bg);
        backdrop-filter: var(--glass-blur);
        -webkit-backdrop-filter: var(--glass-blur);
        border-bottom: 1px solid var(--glass-border);
        box-shadow: var(--glass-shadow);
      }

      .navbar__inner {
        max-width: var(--container-max-width);
        margin: 0 auto;
        padding: 0 var(--container-padding);
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .navbar__logo {
        z-index: 10;
      }

      .logo-text {
        font-family: var(--font-heading);
        font-weight: 900;
        font-size: 1.6rem;
        letter-spacing: -0.03em;
      }

      .logo-accent {
        background: var(--gradient-accent);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .logo-text--footer {
        font-size: 1.8rem;
      }

      .navbar__nav {
        display: flex;
        align-items: center;
        gap: 0.25rem;
      }

      .nav-item {
        position: relative;
      }

      .nav-link {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        padding: 0.5rem 1rem;
        font-weight: 500;
        font-size: 0.925rem;
        border-radius: var(--theme-shape-radius-sm);
        transition: var(--theme-transition);
        color: var(--theme-on-bg);
      }

      .nav-link:hover,
      .nav-link.active {
        background: var(--theme-surface-1);
      }

      .nav-chevron {
        width: 1.1rem;
        height: 1.1rem;
        transition: var(--theme-transition);
      }

      .nav-item:hover .nav-chevron {
        transform: rotate(180deg);
      }

      .nav-dropdown {
        position: absolute;
        top: calc(100% + 0.5rem);
        left: 50%;
        transform: translateX(-50%);
        min-width: 220px;
        background: var(--glass-bg);
        backdrop-filter: var(--glass-blur);
        -webkit-backdrop-filter: var(--glass-blur);
        border: 1px solid var(--glass-border);
        border-radius: var(--theme-shape-radius);
        box-shadow: var(--glass-shadow);
        padding: 0.5rem;
        opacity: 0;
        visibility: hidden;
        transform: translateX(-50%) translateY(8px);
        transition: var(--theme-transition);
      }

      .nav-item:hover .nav-dropdown {
        opacity: 1;
        visibility: visible;
        transform: translateX(-50%) translateY(0);
      }

      .nav-dropdown__link {
        display: block;
        padding: 0.6rem 1rem;
        font-size: 0.9rem;
        border-radius: var(--theme-shape-radius-sm);
        transition: var(--theme-transition);
      }

      .nav-dropdown__link:hover {
        background: var(--theme-surface-1);
      }

      .navbar__actions {
        display: flex;
        align-items: center;
        gap: 1rem;
      }

      /* Mobile Toggle */
      .mobile-toggle {
        display: none;
        flex-direction: column;
        gap: 5px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.5rem;
        z-index: 10;
      }

      .mobile-toggle span {
        display: block;
        width: 24px;
        height: 2px;
        background: var(--theme-on-bg);
        transition: var(--theme-transition);
        border-radius: 2px;
      }

      .mobile-toggle.is-open span:nth-child(1) {
        transform: rotate(45deg) translate(5px, 5px);
      }

      .mobile-toggle.is-open span:nth-child(2) {
        opacity: 0;
      }

      .mobile-toggle.is-open span:nth-child(3) {
        transform: rotate(-45deg) translate(5px, -5px);
      }

      /* Mobile Nav */
      .mobile-nav {
        position: fixed;
        inset: 0;
        z-index: 999;
        background: var(--glass-bg);
        backdrop-filter: blur(24px);
        -webkit-backdrop-filter: blur(24px);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        visibility: hidden;
        transition: var(--theme-transition);
      }

      .mobile-nav.is-open {
        opacity: 1;
        visibility: visible;
      }

      .mobile-nav__inner {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
      }

      .mobile-nav__link {
        font-size: 1.5rem;
        font-weight: 700;
      }

      /* ========================================
         FOOTER
         ======================================== */

      .footer {
        background: var(--theme-primary);
        color: var(--theme-on-primary);
        padding: 4rem 0 2rem;
        margin-top: var(--section-margin);
      }

      .footer__inner {
        max-width: var(--container-max-width);
        margin: 0 auto;
        padding: 0 var(--container-padding);
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1fr;
        gap: 3rem;
      }

      .footer__tagline {
        margin-top: 0.5rem;
        opacity: 0.7;
        font-size: 0.95rem;
      }

      .footer__socials {
        display: flex;
        gap: 0.75rem;
        margin-top: 1.5rem;
      }

      .social-link {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.1);
        transition: var(--theme-transition);
      }

      .social-link:hover {
        background: rgba(255, 255, 255, 0.2);
        transform: translateY(-2px);
      }

      .social-link svg {
        width: 20px;
        height: 20px;
      }

      .footer__list h4 {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        opacity: 0.5;
        margin-bottom: 1rem;
        font-weight: 600;
      }

      .footer__list ul {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
      }

      .footer__list a {
        font-size: 0.925rem;
        opacity: 0.8;
        transition: var(--theme-transition);
      }

      .footer__list a:hover {
        opacity: 1;
      }

      .footer__bottom {
        max-width: var(--container-max-width);
        margin: 3rem auto 0;
        padding: 1.5rem var(--container-padding) 0;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        text-align: center;
        font-size: 0.85rem;
        opacity: 0.5;
      }

      /* ========================================
         RESPONSIVE
         ======================================== */

      @media (max-width: 768px) {
        .navbar__nav {
          display: none;
        }

        .navbar__actions .btn {
          display: none;
        }

        .mobile-toggle {
          display: flex;
        }

        .footer__inner {
          grid-template-columns: 1fr;
          gap: 2rem;
        }
      }

      /* ========================================
         SCROLL REVEAL ANIMATION
         ======================================== */

      .reveal {
        opacity: 0;
        transform: translateY(30px);
        transition: opacity 0.6s ease, transform 0.6s ease;
      }

      .reveal.is-visible {
        opacity: 1;
        transform: translateY(0);
      }
    </style>

    <!-- Scroll Reveal Observer -->
    <script is:inline>
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
          }
        });
      }, { threshold: 0.1 });

      document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

      // Re-observe after View Transitions
      document.addEventListener('astro:page-load', () => {
        document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
      });
    </script>
  </body>
</html>
