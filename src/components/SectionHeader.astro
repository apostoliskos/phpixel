---
export interface Props {
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
  tag?: 'h1' | 'h2' | 'h3';
  light?: boolean;
}

const {
  title,
  subtitle,
  align = 'center',
  tag: Tag = 'h2',
  light = false,
} = Astro.props;
---

<div class:list={['section-header', `section-header--${align}`, { 'section-header--light': light }]}>
  {subtitle && <span class="section-header__eyebrow">{subtitle}</span>}
  <Tag class="section-header__title">{title}</Tag>
  {Astro.slots.has('default') && (
    <p class="section-header__desc">
      <slot />
    </p>
  )}
</div>

<style>
  .section-header {
    margin-bottom: 3rem;
  }

  .section-header--center {
    text-align: center;
    max-width: 680px;
    margin-left: auto;
    margin-right: auto;
  }

  .section-header--left {
    text-align: left;
  }

  .section-header__eyebrow {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: var(--gradient-accent);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.75rem;
  }

  .section-header__title {
    margin-bottom: 1rem;
  }

  .section-header__desc {
    font-size: 1.1rem;
    opacity: 0.7;
    line-height: 1.7;
    max-width: 600px;
  }

  .section-header--center .section-header__desc {
    margin: 0 auto;
  }

  .section-header--light {
    color: #fff;
  }

  .section-header--light .section-header__desc {
    opacity: 0.8;
  }
</style>
