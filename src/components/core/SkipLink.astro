---
// Skip link — πρώτο εστιάσιμο στοιχείο της σελίδας. Κρυμμένο οπτικά μέχρι να
// πάρει focus (Tab), οπότε επιτρέπει σε πληκτρολόγιο/screen reader να
// παρακάμψουν το navbar και να πάνε κατευθείαν στο <main id="content">.
---

<a href="#content" class="skip-link">Μετάβαση στο περιεχόμενο</a>

<style>
  .skip-link {
    position: absolute;
    top: 0;
    left: 0;
    z-index: 2000;
    padding: 0.75rem 1.25rem;
    background: var(--theme-on-bg);
    color: var(--theme-bg);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.95rem;
    border-radius: 0 0 var(--theme-shape-radius-sm) 0;

    /* Visually hidden μέχρι το focus */
    transform: translateY(-120%);
    transition: transform 0.2s ease;
  }

  .skip-link:focus {
    transform: translateY(0);
    outline: 2px solid var(--theme-bg);
    outline-offset: -4px;
  }
</style>
