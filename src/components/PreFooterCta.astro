---
// Standard pre-footer CTA — ίδιο block σε όλες τις σελίδες (εκτός /contact).
import { site } from '../data/site';
---

<section class="pre-footer-cta">
  <div class="container">
    <div class="pre-footer-cta__card reveal">
      <span class="pre-footer-cta__eyebrow">Ας μιλήσουμε</span>
      <h2>Έχεις κάτι στο μυαλό σου;</h2>
      <p>
        Η πρώτη κουβέντα είναι δωρεάν — και ειλικρινής. Αν αυτό που θες δεν σου
        χρειάζεται, θα σου το πούμε.
      </p>
      <a href="/contact" class="btn btn--primary btn--lg pre-footer-cta__btn">
        Πες μας για το project σου
      </a>
      <p class="pre-footer-cta__alt">
        ή γράψε μας στο <a href={`mailto:${site.contact.email}`}>{site.contact.email}</a>
      </p>
    </div>
  </div>
</section>

<style>
  .pre-footer-cta {
    padding: 0 0 5rem;
  }

  .pre-footer-cta__card {
    background: var(--theme-on-bg);
    border-radius: 20px;
    padding: 4rem 2rem;
    text-align: center;
    color: #fff;
  }

  .pre-footer-cta__eyebrow {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 0.6rem;
  }

  .pre-footer-cta__card h2 {
    font-size: clamp(1.6rem, 3.5vw, 2.6rem);
    letter-spacing: -0.03em;
    line-height: 1.15;
    margin-bottom: 0.75rem;
  }

  .pre-footer-cta__card > p {
    font-size: 1rem;
    opacity: 0.55;
    max-width: 520px;
    margin: 0 auto 2rem;
    line-height: 1.7;
  }

  .pre-footer-cta__btn {
    background: #fff;
    color: var(--theme-on-bg);
    border-color: #fff;
  }

  .pre-footer-cta__btn:hover {
    background: var(--theme-surface-1);
    border-color: var(--theme-surface-1);
  }

  .pre-footer-cta__alt {
    margin-top: 1.25rem;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.4);
  }

  .pre-footer-cta__alt a {
    color: rgba(255, 255, 255, 0.65);
    text-decoration: underline;
  }

  .pre-footer-cta__alt a:hover {
    color: #fff;
  }

  @media (max-width: 768px) {
    .pre-footer-cta__card {
      padding: 3rem 1.5rem;
    }
  }
</style>
