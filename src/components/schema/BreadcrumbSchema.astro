---
// BreadcrumbList JSON-LD — η «Αρχική» μπαίνει αυτόματα πρώτη.
// Το τελευταίο item (η τρέχουσα σελίδα) μπορεί να μην έχει path.
import { site } from '../../data/site';

export interface BreadcrumbItem {
  name: string;
  path?: string;
}

export interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [{ name: 'Αρχική', path: '/' }, ...items].map((item, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: item.name,
    ...(item.path ? { item: `${site.url}${item.path}` } : {}),
  })),
};
---

<script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumb)} />
