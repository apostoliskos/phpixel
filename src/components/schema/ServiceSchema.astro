---
// Service JSON-LD για τις σελίδες υπηρεσιών.
import { site } from '../../data/site';

export interface Props {
  serviceType: string;
  name?: string;
  description?: string;
}

const { serviceType, name = serviceType, description } = Astro.props;

const service = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType,
  name,
  ...(description ? { description } : {}),
  areaServed: 'GR',
  provider: {
    '@id': `${site.url}/#organization`,
  },
};
---

<script type="application/ld+json" is:inline set:html={JSON.stringify(service)} />
