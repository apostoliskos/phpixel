---
// Organization + ProfessionalService JSON-LD — μπαίνει σε κάθε σελίδα μέσω του
// BaseLayout. Το ProfessionalService node ενισχύει το local SEO (areaServed,
// address). Σημείωση: ΔΕΝ μπαίνει τηλέφωνο εδώ — ο αριθμός εμφανίζεται μόνο στο
// /contact (απόφαση ιδιοκτήτη).
import { site } from '../../data/site';

const sameAs = [
  site.socials.facebook,
  site.socials.instagram,
  site.socials.linkedin,
];

const organization = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${site.url}/#organization`,
  name: 'phpixel',
  url: `${site.url}`,
  logo: `${site.url}/favicon.png`,
  email: site.contact.email,
  areaServed: 'GR',
  sameAs,
};

const professionalService = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  '@id': `${site.url}/#business`,
  name: 'phpixel',
  url: `${site.url}`,
  image: `${site.url}/social.png`,
  email: site.contact.email,
  areaServed: 'GR',
  address: {
    '@type': 'PostalAddress',
    addressCountry: 'GR',
  },
  sameAs,
};
---

<script type="application/ld+json" is:inline set:html={JSON.stringify(organization)} />
<script type="application/ld+json" is:inline set:html={JSON.stringify(professionalService)} />
