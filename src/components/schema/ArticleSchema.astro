---
// Article JSON-LD για τα blog posts.
import { site } from '../../data/site';

export interface Props {
  headline: string;
  description?: string;
  datePublished: string;
  dateModified?: string;
  image?: string;
  path: string;
}

const { headline, description, datePublished, dateModified, image, path } = Astro.props;

const toISO = (d: string) => {
  const parsed = new Date(d);
  return isNaN(parsed.getTime()) ? d : parsed.toISOString().split('T')[0];
};

const article = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline,
  ...(description ? { description } : {}),
  datePublished: toISO(datePublished),
  dateModified: toISO(dateModified || datePublished),
  ...(image ? { image: `${site.url}${image}` } : {}),
  mainEntityOfPage: `${site.url}${path}`,
  inLanguage: site.lang,
  author: {
    '@type': site.blogAuthor.type,
    name: site.blogAuthor.name,
    url: `${site.url}/`,
  },
  publisher: { '@id': `${site.url}/#organization` },
};
---

<script type="application/ld+json" is:inline set:html={JSON.stringify(article)} />
