---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import GlassCard from '../components/GlassCard.astro';
import CtaSection from '../components/CtaSection.astro';
import { Icon } from 'astro-icon/components';

const features = [
  {
    icon: 'ic:baseline-code',
    title: 'Custom Web Apps',
    desc: 'Ανάπτυξη tailor-made web εφαρμογών με σύγχρονες τεχνολογίες — React, Next.js, Node.js.',
    accent: 'var(--accent-blue)',
  },
  {
    icon: 'ic:baseline-api',
    title: 'API Development',
    desc: 'Σχεδιασμός και ανάπτυξη RESTful & GraphQL APIs για σύνδεση συστημάτων και υπηρεσιών.',
    accent: 'var(--accent-violet)',
  },
  {
    icon: 'ic:baseline-dashboard',
    title: 'Admin Dashboards',
    desc: 'Διαχειριστικά panels με real-time data, charts και analytics για πλήρη έλεγχο της επιχείρησής σας.',
    accent: 'var(--accent-emerald)',
  },
  {
    icon: 'ic:baseline-cloud',
    title: 'Cloud Infrastructure',
    desc: 'Deployment σε AWS, Google Cloud ή Azure με auto-scaling, CI/CD pipelines και monitoring.',
    accent: 'var(--accent-amber)',
  },
  {
    icon: 'ic:baseline-sync',
    title: 'System Integration',
    desc: 'Σύνδεση με ERP, CRM, payment gateways, shipping APIs και third-party υπηρεσίες.',
    accent: 'var(--accent-rose)',
  },
  {
    icon: 'ic:baseline-security',
    title: 'Security & Auth',
    desc: 'Ασφαλή συστήματα authentication, role-based access control και data encryption.',
    accent: 'var(--accent-blue)',
  },
  {
    icon: 'ic:baseline-smartphone',
    title: 'Progressive Web Apps',
    desc: 'PWA εφαρμογές με offline support, push notifications και native-like εμπειρία χρήσης.',
    accent: 'var(--accent-violet)',
  },
  {
    icon: 'ic:baseline-support-agent',
    title: 'Maintenance & Support',
    desc: 'Συνεχής υποστήριξη, bug fixes, feature updates και performance optimization μετά το launch.',
    accent: 'var(--accent-emerald)',
  },
];

const techStacks = [
  { name: 'Frontend', desc: 'React, Next.js, Astro, Vue.js — modern UI frameworks' },
  { name: 'Backend', desc: 'Node.js, Python, PHP — scalable server solutions' },
  { name: 'Database & Cloud', desc: 'PostgreSQL, MongoDB, AWS, Docker, Kubernetes' },
];
---

<BaseLayout
  title="Software Development — Phpixel | Custom Web & Mobile Apps"
  description="Custom software development. Web apps, APIs, dashboards και cloud solutions — tailor-made λύσεις για την επιχείρησή σας."
>

  <!-- Hero -->
  <section class="dev-hero">
    <div class="dev-hero__bg"></div>
    <div class="container dev-hero__inner">
      <div class="dev-hero__content reveal">
        <span class="dev-badge">Software Development</span>
        <h1>
          Custom<br />
          <span class="accent-text">Software</span>
        </h1>
        <p class="dev-hero__sub">
          Αναπτύσσουμε custom λογισμικό που λύνει πραγματικά επιχειρηματικά
          προβλήματα. Scalable, secure και built to last.
        </p>
        <div class="dev-hero__actions">
          <a href="/contact" class="btn btn--primary btn--lg">Ξεκινήστε το project σας</a>
          <a href="/services" class="btn btn--outline btn--lg">Όλες οι υπηρεσίες</a>
        </div>
      </div>

      <!-- Tech Stacks -->
      <div class="dev-hero__platforms reveal" style="transition-delay: 0.2s">
        {techStacks.map((p) => (
          <div class="platform-card">
            <h3>{p.name}</h3>
            <p>{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="dev-features">
    <div class="container">
      <div class="reveal">
        <SectionHeader title="Τι περιλαμβάνει" subtitle="Development Services">
          Ολοκληρωμένες υπηρεσίες ανάπτυξης λογισμικού — από τον σχεδιασμό μέχρι το deployment και τη συντήρηση.
        </SectionHeader>
      </div>

      <div class="features-grid">
        {features.map((f, i) => (
          <div class="reveal" style={`transition-delay: ${i * 0.05}s`}>
            <GlassCard
              icon={f.icon}
              title={f.title}
              description={f.desc}
              accent={f.accent}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CtaSection
    title="Ας χτίσουμε μαζί το επόμενο project σας"
    description="Η πρώτη συνάντηση είναι δωρεάν. Θα συζητήσουμε τις ανάγκες σας και θα σας προτείνουμε τη βέλτιστη τεχνολογική λύση."
    primaryLabel="Επικοινωνία"
    primaryHref="/contact"
    secondaryLabel="6977383488"
    secondaryHref="tel:6977383488"
  />

</BaseLayout>

<style>
  /* Hero */
  .dev-hero {
    position: relative;
    padding: calc(var(--navbar-height) + 4rem) 0 4rem;
  }

  .dev-hero__bg {
    position: absolute;
    inset: 0;
    background: var(--gradient-subtle);
  }

  .dev-hero__inner {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .dev-badge {
    display: inline-block;
    padding: 0.35rem 1rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: var(--theme-surface-1);
    border-radius: 2rem;
    margin-bottom: 1.5rem;
  }

  .dev-hero__content h1 { margin-bottom: 1.5rem; }

  .accent-text {
    background: var(--gradient-accent);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .dev-hero__sub {
    font-size: 1.1rem;
    line-height: 1.75;
    opacity: 0.7;
    max-width: 460px;
    margin-bottom: 2rem;
  }

  .dev-hero__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .dev-hero__platforms {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .platform-card {
    padding: 1.5rem 2rem;
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: var(--theme-shape-radius);
    transition: var(--theme-transition);
  }

  .platform-card:hover {
    transform: translateX(8px);
    border-color: var(--accent-blue);
  }

  .platform-card h3 {
    font-size: 1.1rem;
    margin-bottom: 0.25rem;
  }

  .platform-card p {
    font-size: 0.9rem;
    opacity: 0.6;
  }

  /* Features */
  .dev-features {
    padding: var(--section-padding);
    background: var(--theme-surface-1);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--theme-grid-gap);
  }

  @media (max-width: 1024px) {
    .features-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .dev-hero__inner { grid-template-columns: 1fr; gap: 2rem; }
    .features-grid { grid-template-columns: 1fr; }
  }
</style>
