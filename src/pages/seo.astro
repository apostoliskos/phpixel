---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import GlassCard from '../components/GlassCard.astro';
import CtaSection from '../components/CtaSection.astro';
import { Icon } from 'astro-icon/components';

const features = [
  {
    icon: 'ic:baseline-search',
    title: 'Έρευνα Λέξεων-Κλειδιών',
    desc: 'Αναλύουμε τον κλάδο σας, τη συμπεριφορά αναζήτησης του κοινού σας και τις τάσεις της αγοράς για να εντοπίσουμε τις λέξεις-κλειδιά με τον υψηλότερο δυναμικό ROI — από short-tail φράσεις υψηλού όγκου μέχρι long-tail keywords με σαφή αγοραστική πρόθεση.',
    accent: 'var(--accent-blue)',
  },
  {
    icon: 'ic:baseline-speed',
    title: 'Technical SEO',
    desc: 'Βελτιστοποιούμε τη δομή του site σας σε βάθος: ταχύτητα φόρτωσης, Core Web Vitals (LCP, FID, CLS), crawl budget, XML sitemaps, canonical URLs, hreflang tags, schema markup και σωστή αρχιτεκτονική URL ώστε η Google να ανιχνεύει και να ευρετηριάζει κάθε σελίδα χωρίς εμπόδια.',
    accent: 'var(--accent-violet)',
  },
  {
    icon: 'ic:baseline-article',
    title: 'Content Strategy',
    desc: 'Σχεδιάζουμε ολοκληρωμένη στρατηγική περιεχομένου βασισμένη σε search intent mapping: πληροφοριακό, πλοηγητικό και συναλλακτικό intent. Δημιουργούμε content clusters, pillar pages και θεματικά silos που χτίζουν topical authority και απαντούν στις πραγματικές ερωτήσεις του κοινού σας.',
    accent: 'var(--accent-emerald)',
  },
  {
    icon: 'ic:baseline-link',
    title: 'Link Building',
    desc: 'Εφαρμόζουμε white-hat στρατηγικές link building: digital PR, guest posting σε σχετικά publications, broken link building και δημιουργία linkable assets. Κάθε backlink προέρχεται από σχετικές, υψηλής εγκυρότητας πηγές που ενισχύουν αληθινά το domain authority σας.',
    accent: 'var(--accent-amber)',
  },
  {
    icon: 'ic:baseline-location-on',
    title: 'Τοπικό SEO',
    desc: 'Βελτιστοποιούμε πλήρως το Google Business Profile σας, δημιουργούμε τοπικές αναφορές (citations) σε κατάλληλους καταλόγους, διαχειριζόμαστε αξιολογήσεις και ενσωματώνουμε local schema markup — ώστε η επιχείρησή σας να εμφανίζεται στο Local Pack και στο Google Maps για αναζητήσεις στην περιοχή σας.',
    accent: 'var(--accent-rose)',
  },
  {
    icon: 'ic:baseline-analytics',
    title: 'Analytics & Reporting',
    desc: 'Λαμβάνετε μηνιαίες αναφορές με πλήρη ορατότητα: οργανική επισκεψιμότητα, keyword rankings, click-through rates, conversion paths και bounce rates. Κάθε report συνοδεύεται από στρατηγικές προτάσεις βελτίωσης — όχι απλά νούμερα, αλλά action plan.',
    accent: 'var(--accent-blue)',
  },
  {
    icon: 'ic:baseline-smartphone',
    title: 'Mobile SEO',
    desc: 'Με πάνω από 70% της κίνησης να προέρχεται από κινητά, διασφαλίζουμε ότι το site σας ανταποκρίνεται πλήρως στο mobile-first indexing της Google: γρήγορη φόρτωση, touch-friendly navigation, responsive εικόνες και βέλτιστη εμπειρία χρήστη σε κάθε συσκευή.',
    accent: 'var(--accent-violet)',
  },
  {
    icon: 'ic:baseline-trending-up',
    title: 'Ανάλυση Ανταγωνισμού',
    desc: 'Χαρτογραφούμε πλήρως τον ψηφιακό ανταγωνισμό σας: ποιες λέξεις-κλειδιά κατατάσσονται, τι backlink profile έχουν, ποια content gaps υπάρχουν και πού βρίσκονται οι ανεκμετάλλευτες ευκαιρίες. Η στρατηγική σας βασίζεται σε δεδομένα, όχι σε υποθέσεις.',
    accent: 'var(--accent-emerald)',
  },
];

const approaches = [
  { name: 'On-Page SEO', desc: 'Βελτιστοποίηση title tags, meta descriptions, heading hierarchy, εσωτερικών links, image alt text και content structure ώστε κάθε σελίδα να στοχεύει με ακρίβεια τα σωστά keywords.' },
  { name: 'Off-Page SEO', desc: 'Στρατηγικό link building, digital PR, brand mentions, social signals και ενίσχυση domain authority μέσω αξιόπιστων, σχετικών πηγών.' },
  { name: 'Technical SEO', desc: 'Crawl optimization, Core Web Vitals, structured data (JSON-LD), site architecture, mobile-first indexing και log file analysis για πλήρη τεχνική αρτιότητα.' },
];
---

<BaseLayout
  title="Υπηρεσίες SEO Ελλάδα — Phpixel | Αυξήστε την Οργανική Επισκεψιμότητα & τα Rankings σας"
  description="Επαγγελματικές υπηρεσίες SEO από την Phpixel. Keyword research, technical SEO, content strategy, link building και τοπικό SEO. Μέσος ρυθμός αύξησης οργανικού traffic 180% στους πρώτους 6 μήνες. Δωρεάν SEO Audit."
>

  <!-- Hero -->
  <section class="seo-hero">
    <div class="seo-hero__bg"></div>
    <div class="container seo-hero__inner">
      <div class="seo-hero__content reveal">
        <span class="seo-badge">Βελτιστοποίηση Μηχανών Αναζήτησης</span>
        <h1>
          Υπηρεσίες<br />
          <span class="accent-text">SEO</span>
        </h1>
        <p class="seo-hero__sub">
          Φέρνουμε την επιχείρησή σας στις πρώτες θέσεις της Google με data-driven στρατηγικές SEO.
          Μέσος ρυθμός αύξησης οργανικού traffic 180% στους πρώτους 6 μήνες — με πλήρη διαφάνεια, μετρήσιμα αποτελέσματα και χωρίς δεσμεύσεις.
        </p>
        <div class="seo-hero__actions">
          <a href="/contact" class="btn btn--primary btn--lg">Δωρεάν SEO Audit</a>
          <a href="/services" class="btn btn--outline btn--lg">Δείτε όλες τις υπηρεσίες</a>
        </div>
      </div>

      <!-- Approaches -->
      <div class="seo-hero__platforms reveal" style="transition-delay: 0.2s">
        {approaches.map((p) => (
          <div class="platform-card">
            <h3>{p.name}</h3>
            <p>{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="seo-features">
    <div class="container">
      <div class="reveal">
        <SectionHeader title="Η SEO Προσέγγισή Μας" subtitle="Ολοκληρωμένες Υπηρεσίες">
          Δεν εφαρμόζουμε τυποποιημένα πακέτα. Κάθε στρατηγική SEO σχεδιάζεται εξατομικευμένα γύρω από τους στόχους, τον κλάδο και τον ανταγωνισμό σας — από τεχνική βελτιστοποίηση μέχρι δημιουργία περιεχομένου και link building.
        </SectionHeader>
      </div>

      <div class="features-grid">
        {features.map((f, i) => (
          <div class="reveal" style={`transition-delay: ${i * 0.05}s`}>
            <GlassCard
              icon={f.icon}
              title={f.title}
              description={f.desc}
              accent={f.accent}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CtaSection
    title="Μάθετε πού χάνετε οργανικό traffic — Δωρεάν"
    description="Ζητήστε δωρεάν SEO Audit και λάβετε αναλυτική αναφορά με τα τεχνικά προβλήματα, τις ευκαιρίες κατάταξης και τα βήματα που χρειάζεται το site σας για να ανεβεί στα αποτελέσματα αναζήτησης. Χωρίς δεσμεύσεις."
    primaryLabel="Ζητήστε Δωρεάν Audit"
    primaryHref="/contact"
    secondaryLabel="6977383488"
    secondaryHref="tel:6977383488"
  />

</BaseLayout>

<style>
  /* Hero */
  .seo-hero {
    position: relative;
    padding: calc(var(--navbar-height) + 4rem) 0 4rem;
  }

  .seo-hero__bg {
    position: absolute;
    inset: 0;
    background: var(--gradient-subtle);
  }

  .seo-hero__inner {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .seo-badge {
    display: inline-block;
    padding: 0.35rem 1rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: var(--theme-surface-1);
    border-radius: 2rem;
    margin-bottom: 1.5rem;
  }

  .seo-hero__content h1 { margin-bottom: 1.5rem; }

  .accent-text {
    background: var(--gradient-accent);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .seo-hero__sub {
    font-size: 1.1rem;
    line-height: 1.75;
    opacity: 0.7;
    max-width: 460px;
    margin-bottom: 2rem;
  }

  .seo-hero__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .seo-hero__platforms {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .platform-card {
    padding: 1.5rem 2rem;
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: var(--theme-shape-radius);
    transition: var(--theme-transition);
  }

  .platform-card:hover {
    transform: translateX(8px);
    border-color: var(--accent-blue);
  }

  .platform-card h3 {
    font-size: 1.1rem;
    margin-bottom: 0.25rem;
  }

  .platform-card p {
    font-size: 0.9rem;
    opacity: 0.6;
  }

  /* Features */
  .seo-features {
    padding: var(--section-padding);
    background: var(--theme-surface-1);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--theme-grid-gap);
  }

  @media (max-width: 1024px) {
    .features-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .seo-hero__inner { grid-template-columns: 1fr; gap: 2rem; }
    .features-grid { grid-template-columns: 1fr; }
  }
</style>
