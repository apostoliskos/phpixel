---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaSection from '../components/CtaSection.astro';
import { Icon } from 'astro-icon/components';
import { projects } from '../data/portfolio';

// Συγκεντρώνουμε τα distinct filters από τα ίδια τα data
const categories = ['Όλα', ...Array.from(new Set(projects.map((p) => p.category)))];
---

<BaseLayout
  title="Portfolio — Phpixel | Έργα ιστοσελίδων & e-shop"
  description="Δείτε ένα δείγμα από τα projects μας: e-shops, ιστοσελίδες και custom web apps για ελληνικές επιχειρήσεις. Πραγματικά αποτελέσματα, μετρήσιμη απόδοση."
>
  <!-- Schema.org JSON-LD: CollectionPage -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Phpixel Portfolio',
    url: 'https://phpixel.gr/portfolio',
    description: 'Έργα ιστοσελίδων, e-shop και web apps της Phpixel.',
    hasPart: projects.map((p) => ({
      '@type': 'CreativeWork',
      name: p.name,
      url: `https://phpixel.gr/portfolio/${p.slug}`,
      image: p.thumb,
      description: p.tagline,
    })),
  })} />

  <!-- ============== HERO ============== -->
  <section class="pf-hero">
    <div class="pf-hero__bg" aria-hidden="true"></div>
    <div class="container pf-hero__inner">
      <div class="pf-hero__content reveal">
        <span class="pf-hero__badge">Portfolio</span>
        <h1 class="pf-hero__title">
          Έργα που μιλούν<br />
          <span class="pf-hero__accent">από μόνα τους.</span>
        </h1>
        <p class="pf-hero__sub">
          Από premium portfolio sites μέχρι μεγάλα e-shops με χιλιάδες προϊόντα —
          κάθε project σχεδιάζεται γύρω από έναν στόχο: μετρήσιμα αποτελέσματα.
        </p>

        <div class="pf-hero__stats">
          <div class="pf-stat">
            <span class="pf-stat__num">{projects.length}+</span>
            <span class="pf-stat__label">Live projects</span>
          </div>
          <div class="pf-stat">
            <span class="pf-stat__num">5+</span>
            <span class="pf-stat__label">Χρόνια εμπειρίας</span>
          </div>
          <div class="pf-stat">
            <span class="pf-stat__num">98</span>
            <span class="pf-stat__label">Μ.Ο. PageSpeed Score</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== FILTERS ============== -->
  <section class="pf-filters" aria-label="Φίλτρα κατηγορίας">
    <div class="container">
      <div class="pf-filters__bar reveal">
        {categories.map((cat, i) => (
          <button
            class:list={['pf-filter', { 'is-active': i === 0 }]}
            data-filter={cat === 'Όλα' ? 'all' : cat}
            type="button"
          >
            {cat}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- ============== PROJECT GRID ============== -->
  <section class="pf-grid-section" aria-label="Λίστα έργων">
    <div class="container">
      <div class="pf-grid" id="pf-grid">
        {projects.map((p, idx) => (
          <a
            href={`/portfolio/${p.slug}`}
            class="pf-card reveal"
            data-category={p.category}
            style={`--pf-accent: ${p.accent}; --pf-delay: ${idx * 80}ms`}
            aria-label={`Δείτε το case study: ${p.name}`}
          >
            <div class="pf-card__media">
              <img
                src={p.thumb}
                alt={`Screenshot — ${p.name}`}
                loading={idx < 2 ? 'eager' : 'lazy'}
                decoding="async"
              />
              <div class="pf-card__overlay">
                <span class="pf-card__cta">
                  Δείτε το case study
                  <Icon name="ic:baseline-arrow-forward" class="pf-card__arrow" />
                </span>
              </div>
              <span class="pf-card__category">{p.category}</span>
            </div>

            <div class="pf-card__body">
              <div class="pf-card__head">
                <h3 class="pf-card__title">{p.name}</h3>
                <span class="pf-card__year">{p.year}</span>
              </div>
              <p class="pf-card__tagline">{p.tagline}</p>
              <div class="pf-card__tags">
                {p.tags.slice(0, 4).map((t) => (
                  <span class="pf-chip">{t}</span>
                ))}
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============== CTA ============== -->
  <CtaSection
    title="Έχετε project στο μυαλό σας;"
    description="Πείτε μας λίγα λόγια για την ιδέα σας και θα σας στείλουμε εξατομικευμένη πρόταση μέσα σε 48 ώρες."
    primaryLabel="Ζητήστε προσφορά"
    primaryHref="/contact"
    secondaryLabel="697 738 3488"
    secondaryHref="tel:6977383488"
  />
</BaseLayout>

<!-- =========================================================== -->
<!-- FILTER LOGIC                                                  -->
<!-- =========================================================== -->
<script is:inline>
  function initPortfolioFilters() {
    const buttons = document.querySelectorAll('.pf-filter');
    const cards = document.querySelectorAll('.pf-card');
    if (!buttons.length || !cards.length) return;

    buttons.forEach((btn) => {
      // Avoid double-binding after View Transitions
      if (btn.dataset.bound) return;
      btn.dataset.bound = 'true';

      btn.addEventListener('click', () => {
        const filter = btn.getAttribute('data-filter');
        buttons.forEach((b) => b.classList.remove('is-active'));
        btn.classList.add('is-active');

        cards.forEach((card) => {
          const cat = card.getAttribute('data-category');
          const match = filter === 'all' || cat === filter;
          card.classList.toggle('is-hidden', !match);
        });
      });
    });
  }

  initPortfolioFilters();
  document.addEventListener('astro:page-load', initPortfolioFilters);
</script>

<style>
  /* ===== HERO ===== */
  .pf-hero {
    position: relative;
    padding: calc(var(--navbar-height) + 4rem) 0 4rem;
    overflow: hidden;
  }

  .pf-hero__bg {
    position: absolute;
    inset: 0;
    background: var(--gradient-subtle);
    z-index: 0;
  }

  .pf-hero__bg::before {
    content: '';
    position: absolute;
    top: -10%;
    right: -15%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, var(--accent-blue, #4f9eff) 0%, transparent 70%);
    opacity: 0.12;
    border-radius: 50%;
    filter: blur(60px);
  }

  .pf-hero__bg::after {
    content: '';
    position: absolute;
    bottom: -20%;
    left: -10%;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, var(--accent-violet, #a26bff) 0%, transparent 70%);
    opacity: 0.1;
    border-radius: 50%;
    filter: blur(60px);
  }

  .pf-hero__inner {
    position: relative;
    z-index: 1;
  }

  .pf-hero__content {
    max-width: 720px;
  }

  .pf-hero__badge {
    display: inline-block;
    padding: 0.35rem 1rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: var(--theme-surface-1);
    border-radius: 2rem;
    margin-bottom: 1.5rem;
  }

  .pf-hero__title {
    margin-bottom: 1.5rem;
  }

  .pf-hero__accent {
    background: var(--gradient-accent);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .pf-hero__sub {
    font-size: 1.1rem;
    line-height: 1.75;
    opacity: 0.7;
    max-width: 580px;
    margin-bottom: 2.5rem;
  }

  .pf-hero__stats {
    display: flex;
    gap: 2.5rem;
    flex-wrap: wrap;
  }

  .pf-stat {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .pf-stat__num {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 900;
    letter-spacing: -0.02em;
    line-height: 1;
    background: var(--gradient-accent);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .pf-stat__label {
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    opacity: 0.55;
  }

  /* ===== FILTERS ===== */
  .pf-filters {
    padding: 1.5rem 0 0.5rem;
  }

  .pf-filters__bar {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    padding-bottom: 1.25rem;
  }

  .pf-filter {
    background: transparent;
    border: 1px solid rgba(0, 0, 0, 0.12);
    color: var(--theme-on-bg);
    padding: 0.5rem 1.1rem;
    border-radius: 2rem;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: var(--theme-transition);
  }

  .pf-filter:hover {
    border-color: var(--theme-on-bg);
  }

  .pf-filter.is-active {
    background: var(--theme-on-bg);
    color: var(--theme-bg);
    border-color: var(--theme-on-bg);
  }

  /* ===== GRID ===== */
  .pf-grid-section {
    padding: 2rem 0 4rem;
  }

  .pf-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(360px, 1fr));
    gap: 2rem;
  }

  .pf-card {
    background: var(--theme-surface-0, #fff);
    border-radius: var(--theme-shape-radius, 16px);
    overflow: hidden;
    border: 1px solid rgba(0, 0, 0, 0.06);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
    transition:
      transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1),
      box-shadow 0.4s cubic-bezier(0.2, 0.8, 0.2, 1),
      opacity 0.3s ease;
    display: flex;
    flex-direction: column;
    color: inherit;
    transition-delay: var(--pf-delay, 0ms);
  }

  .pf-card.is-hidden {
    display: none;
  }

  .pf-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.12);
  }

  /* MEDIA */
  .pf-card__media {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--theme-surface-1);
  }

  .pf-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .pf-card:hover .pf-card__media img {
    transform: scale(1.04);
  }

  .pf-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.75) 0%,
      rgba(0, 0, 0, 0) 55%
    );
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: 1.25rem;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .pf-card:hover .pf-card__overlay {
    opacity: 1;
  }

  .pf-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #fff;
    font-weight: 700;
    font-size: 0.9rem;
    transform: translateY(8px);
    transition: transform 0.3s ease;
  }

  .pf-card:hover .pf-card__cta {
    transform: translateY(0);
  }

  .pf-card__arrow {
    width: 18px;
    height: 18px;
  }

  .pf-card__category {
    position: absolute;
    top: 1rem;
    left: 1rem;
    background: var(--glass-bg, rgba(255, 255, 255, 0.85));
    backdrop-filter: var(--glass-blur, blur(12px));
    -webkit-backdrop-filter: var(--glass-blur, blur(12px));
    border: 1px solid var(--glass-border, rgba(255, 255, 255, 0.3));
    color: var(--theme-on-bg);
    padding: 0.3rem 0.8rem;
    border-radius: 2rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  /* BODY */
  .pf-card__body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
  }

  .pf-card__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }

  .pf-card__title {
    font-size: 1.25rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .pf-card__year {
    font-size: 0.78rem;
    font-weight: 600;
    opacity: 0.5;
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }

  .pf-card__tagline {
    font-size: 0.92rem;
    line-height: 1.55;
    opacity: 0.7;
    margin: 0;
  }

  .pf-card__tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-top: auto;
    padding-top: 0.5rem;
  }

  .pf-chip {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    padding: 0.25rem 0.6rem;
    border-radius: var(--theme-shape-radius-sm, 8px);
    background: var(--theme-surface-1);
    color: var(--theme-on-bg);
    opacity: 0.75;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    .pf-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .pf-hero__stats {
      gap: 1.5rem;
    }
  }
</style>
