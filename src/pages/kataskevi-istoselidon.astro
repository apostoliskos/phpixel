---
// Στατική σελίδα — μπαίνει στο sitemap και σερβίρεται prerendered
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import GlassCard from '../components/GlassCard.astro';
import FaqSection from '../components/FaqSection.astro';
import ServiceSchema from '../components/schema/ServiceSchema.astro';
import BreadcrumbSchema from '../components/schema/BreadcrumbSchema.astro';

const features = [
  {
    icon: 'ic:baseline-web',
    title: 'Custom σχεδιασμός',
    desc: 'Σχεδιασμός πάνω στο brand σου, όχι έτοιμο template που έχουν άλλοι πενήντα.',
    accent: 'var(--accent-blue)',
  },
  {
    icon: 'ic:baseline-devices',
    title: 'Σε κάθε συσκευή',
    desc: 'Δουλεύει σωστά παντού: κινητό, tablet, desktop. Εκεί που σε βλέπουν οι πελάτες σου.',
    accent: 'var(--accent-violet)',
  },
  {
    icon: 'ic:baseline-speed',
    title: 'Ταχύτητα',
    desc: 'Σελίδες που φορτώνουν αστραπιαία. Ο επισκέπτης δεν περιμένει, και η Google το μετράει.',
    accent: 'var(--accent-emerald)',
  },
  {
    icon: 'ic:baseline-search',
    title: 'SEO-ready',
    desc: 'Δομή, meta δεδομένα και schema στημένα από την πρώτη μέρα, για να σε βρίσκουν όσοι σε ψάχνουν.',
    accent: 'var(--accent-amber)',
  },
  {
    icon: 'ic:baseline-touch-app',
    title: 'Καθαρά calls-to-action',
    desc: 'Κάθε σελίδα οδηγεί κάπου: σε κλήση, ραντεβού ή αγορά. Όχι απλώς μια «ωραία σελίδα».',
    accent: 'var(--accent-rose)',
  },
  {
    icon: 'ic:baseline-analytics',
    title: 'Μετρήσεις από την αρχή',
    desc: 'Google Analytics και μέτρηση conversions στημένα από το launch. Ξέρεις τι δουλεύει και τι όχι.',
    accent: 'var(--accent-blue)',
  },
  {
    icon: 'ic:baseline-edit',
    title: 'Έτοιμο για A/B δοκιμές',
    desc: 'Δοκιμές σε τίτλους και κουμπιά, ώστε η σελίδα να βελτιώνεται με δεδομένα, όχι με εικασίες.',
    accent: 'var(--accent-violet)',
  },
  {
    icon: 'ic:baseline-integration-instructions',
    title: 'Φόρμες & CRM',
    desc: 'Οι φόρμες σου συνδέονται με το CRM ή το email εργαλείο σου. Κανένα μήνυμα δεν χάνεται.',
    accent: 'var(--accent-emerald)',
  },
];

const pageTypes = [
  {
    name: 'Lead Generation',
    desc: 'Σελίδες που μαζεύουν αιτήματα και ραντεβού, για υπηρεσίες και B2B.',
  },
  {
    name: 'Product Launch',
    desc: 'Landing pages που παρουσιάζουν ένα νέο προϊόν καθαρά και το κάνουν εύκολο να αγοραστεί.',
  },
  {
    name: 'Event & Promo',
    desc: 'Σελίδες για events, προσφορές και καμπάνιες, με έναν στόχο τη φορά.',
  },
];

const faqItems = [
  {
    q: 'Πόσο κοστίζει μια ιστοσελίδα;',
    a: 'Εξαρτάται από το μέγεθος και το τι πρέπει να κάνει: πόσες σελίδες, πόσο custom ο σχεδιασμός, φόρμες, κρατήσεις, πολλές γλώσσες. Θα σου πούμε καθαρά τι χρειάζεσαι, και τι μπορείς να αφήσεις για αργότερα. Παίρνεις αναλυτική προσφορά χωρίς κρυφά κόστη.',
  },
  {
    q: 'Σε πόσο καιρό θα είναι έτοιμη;',
    a: 'Συνήθως 2–4 εβδομάδες, ανάλογα με το περιεχόμενο και τον αριθμό των σελίδων. Θα έχεις preview link από νωρίς, για να βλέπεις την πρόοδο, όχι έκπληξη στο τέλος.',
  },
  {
    q: 'Θα μπορώ να αλλάζω μόνος μου κείμενα και εικόνες;',
    a: 'Ναι. Παραδίδουμε το site με εύχρηστο σύστημα διαχείρισης και σου δείχνουμε πώς να κάνεις τις αλλαγές μόνος σου. Κι αν κολλήσεις, είμαστε ένα μήνυμα μακριά.',
  },
];
---

<BaseLayout
  title="Κατασκευή Ιστοσελίδων & Landing Pages | phpixel"
  description="Γρήγορες, καθαρές ιστοσελίδες και landing pages που εξηγούν τι κάνεις και φέρνουν πελάτες. Custom σχεδιασμός και SEO από την πρώτη γραμμή κώδικα."
  image="/og/kataskevi-istoselidon.png"
>
  <ServiceSchema
    serviceType="Κατασκευή Ιστοσελίδων & Landing Pages"
    description="Γρήγορες, καθαρές ιστοσελίδες και landing pages με custom σχεδιασμό και SEO από την πρώτη γραμμή κώδικα."
  />
  <BreadcrumbSchema items={[{ name: 'Υπηρεσίες', path: '/services' }, { name: 'Ιστοσελίδες & Landing Pages' }]} />

  <!-- Hero -->
  <section class="lp-hero">
    <div class="lp-hero__bg"></div>
    <div class="container lp-hero__inner">
      <div class="lp-hero__content reveal">
        <span class="lp-badge">Ιστοσελίδες</span>
        <h1>
          Ιστοσελίδες &<br />
          <span class="accent-text">Landing Pages</span>
        </h1>
        <p class="lp-hero__sub">
          Η ιστοσελίδα σου είναι συχνά η πρώτη εντύπωση, και δεν υπάρχει δεύτερη
          ευκαιρία γι’ αυτήν. Γι’ αυτό η δημιουργία ιστοσελίδας για εμάς σημαίνει
          σελίδες που φορτώνουν αστραπιαία, δείχνουν καθαρά τι προσφέρεις και οδηγούν
          τον επισκέπτη εκεί που θες: σε επικοινωνία, ραντεβού ή αγορά.
        </p>
      </div>

      <!-- Page Types -->
      <div class="lp-hero__platforms reveal" style="transition-delay: 0.2s">
        {pageTypes.map((p) => (
          <div class="platform-card">
            <h3 class="platform-card__title">{p.name}</h3>
            <p>{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="lp-features">
    <div class="container">
      <div class="reveal">
        <SectionHeader title="Τι περιλαμβάνει" subtitle="Ιστοσελίδες & Landing Pages">
          Κάθε σελίδα που φτιάχνουμε έχει έναν σκοπό: να φέρνει πελάτες, όχι απλώς επισκέψεις.
        </SectionHeader>
      </div>

      <div class="features-grid">
        {features.map((f, i) => (
          <div class="reveal" style={`transition-delay: ${i * 0.05}s`}>
            <GlassCard
              icon={f.icon}
              title={f.title}
              description={f.desc}
              accent={f.accent}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Εταιρικές ιστοσελίδες -->
  <section class="lp-corporate">
    <div class="container lp-corporate__inner reveal">
      <h3>Εταιρικές ιστοσελίδες</h3>
      <p>
        Οι πελάτες σε ψάχνουν στην Google πριν σε πάρουν τηλέφωνο, και σε κρίνουν
        από αυτό που θα δουν. Μια εταιρική ιστοσελίδα από εμάς παρουσιάζει καθαρά τις
        υπηρεσίες και τη δουλειά σου, με δομή που καταλαβαίνει η Google και κείμενα
        που οδηγούν σε επικοινωνία. Χωρίς περιττά εφέ που βαραίνουν τη σελίδα.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <FaqSection items={faqItems} title="Συχνές ερωτήσεις για ιστοσελίδες" />


</BaseLayout>

<style>
  /* Hero */
  .lp-hero {
    position: relative;
    padding: calc(var(--navbar-height) + 4rem) 0 4rem;
  }

  .lp-hero__bg {
    position: absolute;
    inset: 0;
    background: var(--gradient-subtle);
  }

  .lp-hero__inner {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .lp-badge {
    display: inline-block;
    padding: 0.35rem 1rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: var(--theme-surface-1);
    border-radius: 2rem;
    margin-bottom: 1.5rem;
  }

  .lp-hero__content h1 { margin-bottom: 1.5rem; }

  .accent-text {
    background: var(--gradient-accent);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .lp-hero__sub {
    font-size: 1.1rem;
    line-height: 1.75;
    opacity: 0.7;
    max-width: 460px;
  }

  .lp-hero__platforms {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* Εταιρικές ιστοσελίδες */
  .lp-corporate {
    padding: var(--section-padding);
  }

  .lp-corporate__inner {
    max-width: 760px;
    margin: 0 auto;
  }

  .lp-corporate__inner h3 {
    margin-bottom: 1rem;
  }

  .lp-corporate__inner p {
    font-size: 1.05rem;
    line-height: 1.8;
    opacity: 0.7;
  }

  .platform-card {
    padding: 1.5rem 2rem;
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: var(--theme-shape-radius);
    transition: var(--theme-transition);
  }

  .platform-card:hover {
    transform: translateX(8px);
    border-color: var(--accent-blue);
  }

  .platform-card__title {
    font-family: var(--font-heading);
    font-weight: 800;
    line-height: 1.15;
    font-size: 1.1rem;
    margin-bottom: 0.25rem;
    opacity: 1;
  }

  .platform-card p {
    font-size: 0.9rem;
    opacity: 0.6;
  }

  /* Features */
  .lp-features {
    padding: var(--section-padding);
    background: var(--theme-surface-1);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--theme-grid-gap);
  }

  @media (max-width: 1024px) {
    .features-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .lp-hero__inner { grid-template-columns: 1fr; gap: 2rem; }
    .features-grid { grid-template-columns: 1fr; }
  }
</style>
