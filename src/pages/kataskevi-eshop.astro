---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import GlassCard from '../components/GlassCard.astro';
import CtaSection from '../components/CtaSection.astro';
import { Icon } from 'astro-icon/components';

const features = [
  {
    icon: 'ic:baseline-sync',
    title: 'Σύνδεση με ERP',
    desc: 'Αυτόματος συγχρονισμός προϊόντων, πελατών και παραγγελιών με το ERP σας.',
    accent: 'var(--accent-blue)',
  },
  {
    icon: 'ic:baseline-devices',
    title: 'Σύγχρονος Σχεδιασμός',
    desc: 'Mobile-first design με χρήση των πιο σύγχρονων τεχνολογιών. Responsive σε κάθε συσκευή.',
    accent: 'var(--accent-violet)',
  },
  {
    icon: 'ic:baseline-loyalty',
    title: 'Loyalty Program',
    desc: 'Συλλογή πόντων με κάθε αγορά για επιβράβευση των πιστών πελατών σας.',
    accent: 'var(--accent-emerald)',
  },
  {
    icon: 'ic:baseline-search',
    title: 'SEO-Friendly',
    desc: 'Σχεδιασμός βελτιστοποιημένος για SEO, ώστε το e-shop σας να εμφανίζεται ψηλά στις αναζητήσεις.',
    accent: 'var(--accent-blue)',
  },
  {
    icon: 'ic:baseline-shopping-cart-checkout',
    title: 'One-Page Checkout',
    desc: 'Ολοκλήρωση παραγγελίας και πληρωμή σε μία μόνο σελίδα για ευκολία και ταχύτητα.',
    accent: 'var(--accent-amber)',
  },
  {
    icon: 'ic:baseline-shield',
    title: 'Ασφάλεια',
    desc: 'SSL 256-bit κρυπτογράφηση και θωράκιση απέναντι σε κακόβουλες επιθέσεις.',
    accent: 'var(--accent-rose)',
  },
  {
    icon: 'ic:baseline-support-agent',
    title: 'Υποστήριξη',
    desc: 'Τεχνική υποστήριξη, hosting, αναβαθμίσεις και επιδιόρθωση σφαλμάτων.',
    accent: 'var(--accent-violet)',
  },
  {
    icon: 'ic:baseline-local-shipping',
    title: 'Αυτόματα Μεταφορικά',
    desc: 'Αυτόματος υπολογισμός μεταφορικών κόστους με βάση τον προορισμό και το βάρος.',
    accent: 'var(--accent-emerald)',
  },
];

const platforms = [
  { name: 'Shopify', desc: 'Για γρήγορο setup και proven reliability' },
  { name: 'WooCommerce', desc: 'Για flexibility και WordPress integration' },
  { name: 'Custom Build', desc: 'Για πλήρη έλεγχο και tailor-made λύσεις' },
];
---

<BaseLayout
  title="Κατασκευή E-shop — Phpixel | B2C & B2B"
  description="Κατασκευή e-shop B2C & B2B. Shopify, WooCommerce ή custom — προσαρμοσμένο στις ανάγκες της επιχείρησής σας."
>

  <!-- Hero -->
  <section class="eshop-hero">
    <div class="eshop-hero__bg"></div>
    <div class="container eshop-hero__inner">
      <div class="eshop-hero__content reveal">
        <span class="eshop-badge">E-Commerce Solutions</span>
        <h1>
          Κατασκευή<br />
          <span class="accent-text">E-shop</span>
        </h1>
        <p class="eshop-hero__sub">
          Κλείστε ραντεβού για να αναζητήσουμε μαζί τη βέλτιστη λύση
          για εσάς και την επιχείρησή σας. B2C & B2B.
        </p>
        <div class="eshop-hero__actions">
          <a href="/contact" class="btn btn--primary btn--lg">Ξεκινήστε τώρα</a>
          <a href="/services" class="btn btn--outline btn--lg">Όλες οι υπηρεσίες</a>
        </div>
      </div>

      <!-- Platforms -->
      <div class="eshop-hero__platforms reveal" style="transition-delay: 0.2s">
        {platforms.map((p) => (
          <div class="platform-card">
            <h3>{p.name}</h3>
            <p>{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="eshop-features">
    <div class="container">
      <div class="reveal">
        <SectionHeader title="Τι περιλαμβάνει" subtitle="E-shop Features">
          Κάθε e-shop που φτιάχνουμε έρχεται με ένα πλήρες πακέτο δυνατοτήτων.
        </SectionHeader>
      </div>

      <div class="features-grid">
        {features.map((f, i) => (
          <div class="reveal" style={`transition-delay: ${i * 0.05}s`}>
            <GlassCard
              icon={f.icon}
              title={f.title}
              description={f.desc}
              accent={f.accent}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CtaSection
    title="Ξεκινήστε το E-shop σας σήμερα"
    description="Η πρώτη συνάντηση είναι δωρεάν. Θα αναλύσουμε μαζί τις ανάγκες σας και θα σας προτείνουμε τη βέλτιστη λύση."
    primaryLabel="Επικοινωνία"
    primaryHref="/contact"
    secondaryLabel="6977383488"
    secondaryHref="tel:6977383488"
  />

</BaseLayout>

<style>
  /* Hero */
  .eshop-hero {
    position: relative;
    padding: calc(var(--navbar-height) + 4rem) 0 4rem;
  }

  .eshop-hero__bg {
    position: absolute;
    inset: 0;
    background: var(--gradient-subtle);
  }

  .eshop-hero__inner {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .eshop-badge {
    display: inline-block;
    padding: 0.35rem 1rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: var(--theme-surface-1);
    border-radius: 2rem;
    margin-bottom: 1.5rem;
  }

  .eshop-hero__content h1 { margin-bottom: 1.5rem; }

  .accent-text {
    background: var(--gradient-accent);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .eshop-hero__sub {
    font-size: 1.1rem;
    line-height: 1.75;
    opacity: 0.7;
    max-width: 460px;
    margin-bottom: 2rem;
  }

  .eshop-hero__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .eshop-hero__platforms {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .platform-card {
    padding: 1.5rem 2rem;
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: var(--theme-shape-radius);
    transition: var(--theme-transition);
  }

  .platform-card:hover {
    transform: translateX(8px);
    border-color: var(--accent-blue);
  }

  .platform-card h3 {
    font-size: 1.1rem;
    margin-bottom: 0.25rem;
  }

  .platform-card p {
    font-size: 0.9rem;
    opacity: 0.6;
  }

  /* Features */
  .eshop-features {
    padding: var(--section-padding);
    background: var(--theme-surface-1);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--theme-grid-gap);
  }

  @media (max-width: 1024px) {
    .features-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .eshop-hero__inner { grid-template-columns: 1fr; gap: 2rem; }
    .features-grid { grid-template-columns: 1fr; }
  }
</style>
