---
// Στατική σελίδα — μπαίνει στο sitemap και σερβίρεται prerendered
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import GlassCard from '../components/GlassCard.astro';
import FaqSection from '../components/FaqSection.astro';
import ServiceSchema from '../components/schema/ServiceSchema.astro';
import BreadcrumbSchema from '../components/schema/BreadcrumbSchema.astro';

const features = [
  {
    icon: 'ic:baseline-sync',
    title: 'Σύνδεση με ERP',
    desc: 'Αυτόματος συγχρονισμός προϊόντων, αποθεμάτων και παραγγελιών με το ERP σου, και συνδέσεις με courier, Skroutz και marketplaces.',
    accent: 'var(--accent-blue)',
  },
  {
    icon: 'ic:baseline-devices',
    title: 'Σχεδιασμός για το κινητό',
    desc: 'Οι περισσότερες αγορές γίνονται πλέον από κινητό. Εκεί σχεδιάζουμε πρώτα.',
    accent: 'var(--accent-violet)',
  },
  {
    icon: 'ic:baseline-loyalty',
    title: 'Loyalty & επιβράβευση',
    desc: 'Πόντοι, εκπτώσεις και κίνητρα για να ξανάρθουν οι πελάτες σου.',
    accent: 'var(--accent-emerald)',
  },
  {
    icon: 'ic:baseline-search',
    title: 'SEO από κατασκευής',
    desc: 'Δομή, ταχύτητα και δεδομένα στημένα ώστε να σε βρίσκει η Google και τα AI εργαλεία.',
    accent: 'var(--accent-blue)',
  },
  {
    icon: 'ic:baseline-shopping-cart-checkout',
    title: 'One-page checkout',
    desc: 'Ολοκλήρωση παραγγελίας σε μία σελίδα. Λιγότερα βήματα, λιγότερα παρατημένα καλάθια.',
    accent: 'var(--accent-amber)',
  },
  {
    icon: 'ic:baseline-shield',
    title: 'Ασφάλεια',
    desc: 'Ασφαλείς πληρωμές και προστασία δεδομένων, φροντισμένα από εμάς, χωρίς να χρειάζεται να ξέρεις πώς.',
    accent: 'var(--accent-rose)',
  },
  {
    icon: 'ic:baseline-support-agent',
    title: 'Φροντίδα μετά το launch',
    desc: 'Ενημερώσεις, backups, φιλοξενία και ένας άνθρωπος που απαντάει όταν κάτι προκύψει.',
    accent: 'var(--accent-violet)',
  },
  {
    icon: 'ic:baseline-local-shipping',
    title: 'Αυτόματα μεταφορικά',
    desc: 'Υπολογισμός μεταφορικών με βάση προορισμό και βάρος, χωρίς χειροκίνητη δουλειά.',
    accent: 'var(--accent-emerald)',
  },
];

const platforms = [
  {
    name: 'WooCommerce',
    desc: 'Η πιο διαδεδομένη πλατφόρμα e-shop παγκοσμίως. Ευέλικτη, επεκτάσιμη και δική σου, χωρίς μηνιαία εξάρτηση από τρίτους.',
  },
  {
    name: 'Custom κατασκευή',
    desc: 'Όταν το προϊόν ή η ροή σου δεν χωράει σε καλούπια, το χτίζουμε από το μηδέν, ακριβώς στα μέτρα σου.',
  },
  {
    name: 'CS-Cart',
    desc: 'Για marketplaces, B2B και μεγάλους καταλόγους με ιδιαίτερες απαιτήσεις.',
  },
];

const faqItems = [
  {
    q: 'Πόσο κοστίζει ένα e-shop;',
    a: 'Εξαρτάται από το τι χρειάζεσαι: πόσα προϊόντα έχεις, αν θες σύνδεση με ERP, courier ή Skroutz, πόσο custom θα είναι ο σχεδιασμός. Στην ελληνική αγορά οι τιμές έχουν τεράστιο εύρος, γι’ αυτό δεν πετάμε νούμερα στα τυφλά. Θα δούμε μαζί τι πραγματικά χρειάζεσαι (και τι όχι) και θα πάρεις αναλυτική προσφορά χωρίς κρυφά κόστη. Η πρώτη κουβέντα δεν σε δεσμεύει σε τίποτα.',
  },
  {
    q: 'Έχω ήδη e-shop που δεν αποδίδει. Το αναλαμβάνετε;',
    a: 'Ναι, και είναι από τις πιο συχνές δουλειές μας. Ξεκινάμε με έναν έλεγχο σε ταχύτητα, SEO και εμπειρία αγοράς, και σου λέμε τι φταίει και τι αξίζει να διορθωθεί. Καμιά φορά δεν χρειάζεσαι καινούριο site, χρειάζεσαι το σωστό χέρι στο υπάρχον.',
  },
  {
    q: 'Συνδέεται το e-shop με το ERP ή το λογιστικό μου;',
    a: 'Ναι. Στήνουμε αυτόματο συγχρονισμό προϊόντων, αποθεμάτων και παραγγελιών με το ERP σου, καθώς και συνδέσεις με courier, τρόπους πληρωμής και πλατφόρμες όπως το Skroutz.',
  },
  {
    q: 'Τι γίνεται μετά το launch;',
    a: 'Δεν εξαφανιζόμαστε. Αναλαμβάνουμε τη φροντίδα του e-shop (ενημερώσεις, backups, ασφάλεια, φιλοξενία) με πακέτα υποστήριξης, ώστε να έχεις πάντα έναν άνθρωπο να παίρνει τηλέφωνο.',
  },
];
---

<BaseLayout
  title="Κατασκευή E-shop με WooCommerce ή Custom Λύση | phpixel"
  description="Κατασκευή e-shop για B2C & B2B: WooCommerce, custom ή CS-Cart. Σύνδεση με ERP, courier και Skroutz. Στημένο για πωλήσεις, όχι απλώς για να υπάρχει."
  image="/og/kataskevi-eshop.png"
>
  <ServiceSchema
    serviceType="Κατασκευή E-shop"
    description="Κατασκευή e-shop για B2C & B2B: WooCommerce, custom ή CS-Cart, με σύνδεση σε ERP, courier και Skroutz."
  />
  <BreadcrumbSchema items={[{ name: 'Υπηρεσίες', path: '/services' }, { name: 'Κατασκευή E-shop' }]} />

  <!-- Hero -->
  <section class="eshop-hero">
    <div class="eshop-hero__bg"></div>
    <div class="container eshop-hero__inner">
      <div class="eshop-hero__content reveal">
        <span class="eshop-badge">E-commerce</span>
        <h1>
          Κατασκευή<br />
          <span class="accent-text">E-shop</span>
        </h1>
        <p class="eshop-hero__sub">
          Ένα e-shop δεν είναι απλώς ένας κατάλογος με καλάθι. Είναι το κατάστημά σου
          που δουλεύει όλο το 24ωρο. Γι' αυτό η κατασκευή ηλεκτρονικού καταστήματος
          θέλει σωστή βάση από την αρχή: γρήγορο, εύχρηστο στο κινητό και έτοιμο να
          φέρνει παραγγελίες, B2C ή B2B.
        </p>
      </div>

      <!-- Platforms -->
      <div class="eshop-hero__platforms reveal" style="transition-delay: 0.2s">
        {platforms.map((p) => (
          <div class="platform-card">
            <h3 class="platform-card__title">{p.name}</h3>
            <p>{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="eshop-features">
    <div class="container">
      <div class="reveal">
        <SectionHeader title="Τι περιλαμβάνει" subtitle="E-shop">
          Η δημιουργία eshop για εμάς περιλαμβάνει όσα χρειάζεσαι για να πουλάς, όχι έξτρα που δεν θα χρησιμοποιήσεις ποτέ.
        </SectionHeader>
      </div>

      <div class="features-grid">
        {features.map((f, i) => (
          <div class="reveal" style={`transition-delay: ${i * 0.05}s`}>
            <GlassCard
              icon={f.icon}
              title={f.title}
              description={f.desc}
              accent={f.accent}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- B2B e-shop -->
  <section class="eshop-b2b">
    <div class="container eshop-b2b__inner reveal">
      <h3>B2B e-shop</h3>
      <p>
        Πουλάς χονδρική; Ένα B2B e-shop θέλει άλλα πράγματα από ένα B2C: τιμές ανά
        πελάτη ή ομάδα πελατών, ελάχιστες ποσότητες, παραγγελίες με τιμολόγιο και
        συγχρονισμό με το ERP σου. Τα στήνουμε πάνω στο πώς δουλεύει ήδη η χονδρική
        σου, όχι ανάποδα.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <FaqSection items={faqItems} title="Συχνές ερωτήσεις για e-shop" />


</BaseLayout>

<style>
  /* Hero */
  .eshop-hero {
    position: relative;
    padding: calc(var(--navbar-height) + 4rem) 0 4rem;
  }

  .eshop-hero__bg {
    position: absolute;
    inset: 0;
    background: var(--gradient-subtle);
  }

  .eshop-hero__inner {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .eshop-badge {
    display: inline-block;
    padding: 0.35rem 1rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: var(--theme-surface-1);
    border-radius: 2rem;
    margin-bottom: 1.5rem;
  }

  .eshop-hero__content h1 { margin-bottom: 1.5rem; }

  .accent-text {
    background: var(--gradient-accent);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .eshop-hero__sub {
    font-size: 1.1rem;
    line-height: 1.75;
    opacity: 0.7;
    max-width: 460px;
  }

  .eshop-hero__platforms {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* B2B e-shop */
  .eshop-b2b {
    padding: var(--section-padding);
  }

  .eshop-b2b__inner {
    max-width: 760px;
    margin: 0 auto;
  }

  .eshop-b2b__inner h3 {
    margin-bottom: 1rem;
  }

  .eshop-b2b__inner p {
    font-size: 1.05rem;
    line-height: 1.8;
    opacity: 0.7;
  }

  .platform-card {
    padding: 1.5rem 2rem;
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: var(--theme-shape-radius);
    transition: var(--theme-transition);
  }

  .platform-card:hover {
    transform: translateX(8px);
    border-color: var(--accent-blue);
  }

  .platform-card__title {
    font-family: var(--font-heading);
    font-weight: 800;
    line-height: 1.15;
    font-size: 1.1rem;
    margin-bottom: 0.25rem;
    opacity: 1;
  }

  .platform-card p {
    font-size: 0.9rem;
    opacity: 0.6;
  }

  /* Features */
  .eshop-features {
    padding: var(--section-padding);
    background: var(--theme-surface-1);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--theme-grid-gap);
  }

  @media (max-width: 1024px) {
    .features-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .eshop-hero__inner { grid-template-columns: 1fr; gap: 2rem; }
    .features-grid { grid-template-columns: 1fr; }
  }
</style>
