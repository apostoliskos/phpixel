---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="404 — Σελίδα Δεν Βρέθηκε | Phpixel"
  description="Η σελίδα που ψάχνετε δεν υπάρχει ή έχει μετακινηθεί."
>

  <section class="error-page">
    <div class="container error-page__inner">
      <div class="error-content reveal">
        <span class="error-badge">Ωπ!</span>
        <h1 class="error-num">404</h1>
        <h2>Σελίδα Δεν Βρέθηκε</h2>
        <p class="error-desc">
          Η σελίδα που ψάχνετε δεν υπάρχει ή μετακόμισε αλλού.
        </p>
        <div class="error-actions">
          <a href="/" class="btn btn--primary">Πίσω στην Αρχική</a>
          <a href="/contact" class="btn btn--outline">Επικοινωνία</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .error-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding-top: var(--navbar-height);
  }

  .error-badge {
    display: inline-block;
    padding: 0.35rem 1rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: var(--theme-surface-1);
    border-radius: 2rem;
    margin-bottom: 1rem;
  }

  .error-num {
    font-size: clamp(6rem, 15vw, 12rem);
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.05em;
    background: var(--gradient-accent);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.5rem;
  }

  .error-content h2 {
    margin-bottom: 1rem;
  }

  .error-desc {
    font-size: 1.1rem;
    opacity: 0.6;
    margin-bottom: 2rem;
  }

  .error-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
