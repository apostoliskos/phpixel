---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import GlassCard from '../components/GlassCard.astro';
import CtaSection from '../components/CtaSection.astro';
import { Icon } from 'astro-icon/components';

const features = [
  {
    icon: 'ic:baseline-campaign',
    title: 'Social Media Strategy',
    desc: 'Ολοκληρωμένη στρατηγική social media προσαρμοσμένη στους στόχους και το κοινό της επιχείρησής σας.',
    accent: 'var(--accent-blue)',
  },
  {
    icon: 'ic:baseline-photo-library',
    title: 'Content Creation',
    desc: 'Δημιουργία ελκυστικού περιεχομένου — posts, stories, reels και carousels που ξεχωρίζουν.',
    accent: 'var(--accent-violet)',
  },
  {
    icon: 'ic:baseline-ads-click',
    title: 'Paid Advertising',
    desc: 'Διαχείριση διαφημιστικών καμπανιών σε Facebook, Instagram, TikTok και LinkedIn με μέγιστο ROI.',
    accent: 'var(--accent-emerald)',
  },
  {
    icon: 'ic:baseline-groups',
    title: 'Community Management',
    desc: 'Διαχείριση κοινότητας, απάντηση σε σχόλια και μηνύματα, και ενίσχυση του engagement.',
    accent: 'var(--accent-amber)',
  },
  {
    icon: 'ic:baseline-analytics',
    title: 'Performance Analytics',
    desc: 'Μηνιαίες αναφορές με KPIs, reach, engagement rate, conversions και ROI ανάλυση.',
    accent: 'var(--accent-rose)',
  },
  {
    icon: 'ic:baseline-people',
    title: 'Influencer Marketing',
    desc: 'Εντοπισμός και συνεργασία με influencers που ταιριάζουν στο brand σας για αυθεντική προβολή.',
    accent: 'var(--accent-blue)',
  },
  {
    icon: 'ic:baseline-schedule',
    title: 'Content Calendar',
    desc: 'Οργανωμένο πρόγραμμα δημοσιεύσεων με στρατηγικό timing για μέγιστη απήχηση.',
    accent: 'var(--accent-violet)',
  },
  {
    icon: 'ic:baseline-auto-graph',
    title: 'Growth Hacking',
    desc: 'Τεχνικές ταχείας ανάπτυξης — viral campaigns, giveaways, UGC και strategic partnerships.',
    accent: 'var(--accent-emerald)',
  },
];

const platforms = [
  { name: 'Facebook & Instagram', desc: 'Ads, posts, stories, reels και shop integration' },
  { name: 'TikTok & YouTube', desc: 'Video content, short-form και long-form strategy' },
  { name: 'LinkedIn & Google', desc: 'B2B marketing, Google Ads και remarketing' },
];
---

<BaseLayout
  title="Social Media Marketing — Phpixel | Διαχείριση & Διαφήμιση"
  description="Υπηρεσίες social media marketing. Στρατηγική, content creation, paid advertising και community management για ανάπτυξη της επιχείρησής σας."
>

  <!-- Hero -->
  <section class="smm-hero">
    <div class="smm-hero__bg"></div>
    <div class="container smm-hero__inner">
      <div class="smm-hero__content reveal">
        <span class="smm-badge">Digital Marketing</span>
        <h1>
          Social Media<br />
          <span class="accent-text">Marketing</span>
        </h1>
        <p class="smm-hero__sub">
          Αυξήστε την αναγνωρισιμότητα του brand σας και μετατρέψτε followers
          σε πελάτες. Στρατηγική, content και advertising σε ένα πακέτο.
        </p>
        <div class="smm-hero__actions">
          <a href="/contact" class="btn btn--primary btn--lg">Δωρεάν Συμβουλευτική</a>
          <a href="/services" class="btn btn--outline btn--lg">Όλες οι υπηρεσίες</a>
        </div>
      </div>

      <!-- Platforms -->
      <div class="smm-hero__platforms reveal" style="transition-delay: 0.2s">
        {platforms.map((p) => (
          <div class="platform-card">
            <h3>{p.name}</h3>
            <p>{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="smm-features">
    <div class="container">
      <div class="reveal">
        <SectionHeader title="Τι περιλαμβάνει" subtitle="Social Media Services">
          Ολοκληρωμένες υπηρεσίες social media marketing — από τη στρατηγική μέχρι την εκτέλεση.
        </SectionHeader>
      </div>

      <div class="features-grid">
        {features.map((f, i) => (
          <div class="reveal" style={`transition-delay: ${i * 0.05}s`}>
            <GlassCard
              icon={f.icon}
              title={f.title}
              description={f.desc}
              accent={f.accent}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CtaSection
    title="Ενισχύστε την παρουσία σας στα social media"
    description="Ξεκινήστε με δωρεάν social media audit. Θα αναλύσουμε τα κανάλια σας και θα σας προτείνουμε στρατηγική ανάπτυξης."
    primaryLabel="Επικοινωνία"
    primaryHref="/contact"
    secondaryLabel="6977383488"
    secondaryHref="tel:6977383488"
  />

</BaseLayout>

<style>
  /* Hero */
  .smm-hero {
    position: relative;
    padding: calc(var(--navbar-height) + 4rem) 0 4rem;
  }

  .smm-hero__bg {
    position: absolute;
    inset: 0;
    background: var(--gradient-subtle);
  }

  .smm-hero__inner {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .smm-badge {
    display: inline-block;
    padding: 0.35rem 1rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: var(--theme-surface-1);
    border-radius: 2rem;
    margin-bottom: 1.5rem;
  }

  .smm-hero__content h1 { margin-bottom: 1.5rem; }

  .accent-text {
    background: var(--gradient-accent);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .smm-hero__sub {
    font-size: 1.1rem;
    line-height: 1.75;
    opacity: 0.7;
    max-width: 460px;
    margin-bottom: 2rem;
  }

  .smm-hero__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .smm-hero__platforms {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .platform-card {
    padding: 1.5rem 2rem;
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: var(--theme-shape-radius);
    transition: var(--theme-transition);
  }

  .platform-card:hover {
    transform: translateX(8px);
    border-color: var(--accent-blue);
  }

  .platform-card h3 {
    font-size: 1.1rem;
    margin-bottom: 0.25rem;
  }

  .platform-card p {
    font-size: 0.9rem;
    opacity: 0.6;
  }

  /* Features */
  .smm-features {
    padding: var(--section-padding);
    background: var(--theme-surface-1);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--theme-grid-gap);
  }

  @media (max-width: 1024px) {
    .features-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .smm-hero__inner { grid-template-columns: 1fr; gap: 2rem; }
    .features-grid { grid-template-columns: 1fr; }
  }
</style>
