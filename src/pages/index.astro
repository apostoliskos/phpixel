---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServicesGrid from '../components/ServicesGrid.astro';
import CtaSection from '../components/CtaSection.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { Icon } from 'astro-icon/components';
import { services } from '../data/services';
import { site } from '../data/site';
---

<BaseLayout
  title={`${site.name} | E-shop, Websites, Custom Apps`}
  description="Phpixel — Κατασκευή e-shop, ιστοσελίδων, custom web apps, hosting & maintenance. Ολοκληρωμένες ψηφιακές λύσεις."
  darkHero={true}
>

  <!-- ========== HERO SECTION ========== -->
  <section class="hero">
    <div class="hero__bg"></div>
    <div class="container hero__inner">
      <div class="hero__content">
        <span class="hero__badge reveal">From idea to pixel and code</span>
        <h1 class="hero__title reveal" style="transition-delay: 0.1s">
          Κάνε την Ιδέα σου<br />
          <span class="hero__title-accent">Πραγματικότητα</span>
        </h1>
        <p class="hero__subtitle reveal" style="transition-delay: 0.2s">
          E-shop, websites, custom apps & hosting. Δημιουργούμε ψηφιακές λύσεις
          που φέρνουν αποτελέσματα.
        </p>
        <div class="hero__actions reveal" style="transition-delay: 0.3s">
          <a href="/contact" class="btn btn--primary btn--lg">
            <Icon name="ic:baseline-mail" class="btn-icon" />
            Ξεκίνα τώρα
          </a>
          <a href="/services" class="btn btn--outline btn--lg hero__outline-btn">
            Οι υπηρεσίες μας
            <Icon name="ic:baseline-arrow-forward" class="btn-icon" />
          </a>
        </div>
      </div>

      <div class="hero__visual reveal" style="transition-delay: 0.4s">
        <div class="hero__card hero__card--1">
          <Icon name="ic:baseline-shopping-cart" class="hero-card-icon" />
          <span>E-shop</span>
        </div>
        <div class="hero__card hero__card--2">
          <Icon name="ic:baseline-language" class="hero-card-icon" />
          <span>Websites</span>
        </div>
        <div class="hero__card hero__card--3">
          <Icon name="ic:baseline-code" class="hero-card-icon" />
          <span>Web Apps</span>
        </div>
        <div class="hero__card hero__card--4">
          <Icon name="ic:baseline-cloud" class="hero-card-icon" />
          <span>Hosting</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== SERVICES GRID ========== -->
  <ServicesGrid services={services} />

  <!-- ========== WHY US SECTION ========== -->
  <section class="why-us">
    <div class="container">
      <div class="reveal">
        <SectionHeader title="Γιατί Εμάς" subtitle="Our Approach">
          Συνδυάζουμε τεχνολογία, σχεδιασμό και στρατηγική
          για να φτιάξουμε κάτι που πραγματικά δουλεύει.
        </SectionHeader>
      </div>

      <div class="why-us__grid">
        <div class="why-us__item reveal">
          <div class="why-us__number">01</div>
          <h3>Modern Tech Stack</h3>
          <p>Astro, Next.js, React, Shopify — χρησιμοποιούμε τις πιο σύγχρονες τεχνολογίες για ταχύτητα και απόδοση.</p>
        </div>
        <div class="why-us__item reveal" style="transition-delay: 0.1s">
          <div class="why-us__number">02</div>
          <h3>SEO-First Design</h3>
          <p>Κάθε σελίδα βελτιστοποιημένη για τις μηχανές αναζήτησης. Core Web Vitals, semantic HTML, structured data.</p>
        </div>
        <div class="why-us__item reveal" style="transition-delay: 0.2s">
          <div class="why-us__number">03</div>
          <h3>Dedicated Support</h3>
          <p>Δεν σε αφήνουμε μετά το launch. Συνεχής υποστήριξη, updates και monitoring 24/7.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== CTA SECTION ========== -->
  <CtaSection
    title="Ας δημιουργήσουμε κάτι μαζί"
    description="Μην διστάσεις να επικοινωνήσεις μαζί μας. Η ιδέα σου αξίζει να γίνει πραγματικότητα."
    primaryLabel="Επικοινωνία"
    primaryHref="/contact"
    secondaryLabel="6977383488"
    secondaryHref="tel:6977383488"
  />

</BaseLayout>

<style>
  /* ========================================
     HERO
     ======================================== */

  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-top: var(--navbar-height);
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    background: var(--gradient-hero);
    z-index: 0;
  }

  .hero__bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 20% 50%, rgba(59, 130, 246, 0.15) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 50%, rgba(139, 92, 246, 0.1) 0%, transparent 60%);
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 4rem;
    padding: 4rem var(--container-padding);
  }

  .hero__content {
    color: #fff;
  }

  .hero__badge {
    display: inline-block;
    padding: 0.4rem 1rem;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 2rem;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    margin-bottom: 1.5rem;
    backdrop-filter: blur(8px);
  }

  .hero__title {
    color: #fff;
    margin-bottom: 1.25rem;
  }

  .hero__title-accent {
    background: var(--gradient-accent);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero__subtitle {
    font-size: 1.15rem;
    opacity: 0.8;
    line-height: 1.7;
    max-width: 480px;
    margin-bottom: 2rem;
  }

  .hero__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero__outline-btn {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.3);
  }

  .hero__outline-btn:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.5);
    color: #fff;
  }

  .btn-icon {
    width: 20px;
    height: 20px;
  }

  /* Hero Visual — Floating Cards */
  .hero__visual {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    padding: 2rem;
  }

  .hero__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 2rem 1.5rem;
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--theme-shape-radius);
    color: #fff;
    font-weight: 600;
    font-size: 0.95rem;
    transition: var(--theme-transition);
    animation: float 6s ease-in-out infinite;
  }

  .hero__card:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.2);
    transform: translateY(-4px);
  }

  .hero__card--1 { animation-delay: 0s; }
  .hero__card--2 { animation-delay: 1.5s; }
  .hero__card--3 { animation-delay: 3s; }
  .hero__card--4 { animation-delay: 4.5s; }

  .hero-card-icon {
    width: 36px;
    height: 36px;
    opacity: 0.9;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  /* ========================================
     WHY US SECTION
     ======================================== */

  .why-us {
    padding: var(--section-padding);
    background: var(--theme-surface-1);
  }

  .why-us__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .why-us__item {
    padding: 2rem;
  }

  .why-us__number {
    font-family: var(--font-heading);
    font-size: 3rem;
    font-weight: 900;
    background: var(--gradient-accent);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
    margin-bottom: 1rem;
  }

  .why-us__item h3 {
    margin-bottom: 0.75rem;
  }

  .why-us__item p {
    font-size: 0.95rem;
    opacity: 0.7;
    line-height: 1.65;
  }

  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding-top: var(--navbar-height);
    }

    .hero__inner {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 2rem;
      padding: 2rem var(--container-padding);
    }

    .hero__subtitle {
      margin-left: auto;
      margin-right: auto;
      font-size: 1rem;
    }

    .hero__actions {
      justify-content: center;
    }

    .hero__visual {
      padding: 0;
      gap: 0.75rem;
    }

    .hero__card {
      padding: 1.25rem 0.75rem;
      font-size: 0.85rem;
      gap: 0.5rem;
    }

    .hero-card-icon {
      width: 28px;
      height: 28px;
    }

    .why-us__grid {
      grid-template-columns: 1fr;
    }

    .why-us__item {
      padding: 1.5rem 1rem;
    }
  }

  /* Small screens — 420px and below */
  @media (max-width: 420px) {
    .hero__inner {
      padding: 1.5rem 1rem;
      gap: 1.5rem;
    }

    .hero__badge {
      font-size: 0.7rem;
      padding: 0.3rem 0.75rem;
      margin-bottom: 1rem;
    }

    .hero__subtitle {
      font-size: 0.9rem;
      margin-bottom: 1.5rem;
    }

    .hero__actions {
      flex-direction: column;
      align-items: center;
      gap: 0.75rem;
    }

    .hero__actions .btn {
      width: 100%;
      justify-content: center;
      padding: 0.85rem 1.25rem;
      font-size: 0.9rem;
    }

    .hero__visual {
      gap: 0.5rem;
    }

    .hero__card {
      padding: 1rem 0.5rem;
      font-size: 0.8rem;
      gap: 0.4rem;
      border-radius: 0.75rem;
    }

    .hero-card-icon {
      width: 24px;
      height: 24px;
    }

    .why-us__number {
      font-size: 2.25rem;
    }

    .why-us__item {
      padding: 1rem 0.5rem;
    }
  }
</style>