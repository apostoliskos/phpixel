---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
import { services } from '../data/services';
import { site } from '../data/site';
import { projects } from '../data/portfolio';
import { testimonials } from '../data/testimonials';
import { footerSocials } from '../config/footer';
---

<BaseLayout
  title={`${site.name} — Κατασκευή E-shop, Ιστοσελίδων & Web Apps`}
  description="Phpixel — Κατασκευή e-shop, ιστοσελίδων, custom web apps, hosting & maintenance. Ολοκληρωμένες ψηφιακές λύσεις που φέρνουν μετρήσιμα αποτελέσματα."
>

  <!-- ═══════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════ -->
  <section class="hero">
    <div class="container hero__container">
      <div class="hero__badge reveal">
        <span class="hero__badge-dot"></span>
        Δεχόμαστε νέα projects
      </div>
      <h1 class="hero__title reveal">
        Φτιάχνουμε ψηφιακές<br/>
        εμπειρίες που <em>πουλάνε</em>.
      </h1>
      <p class="hero__sub reveal">
        E-shop, websites, custom web apps & hosting.<br class="hide-mobile"/>
        Σχεδιάζουμε, αναπτύσσουμε και υποστηρίζουμε — εσείς αναπτύσσεστε.
      </p>
      <div class="hero__cta reveal">
        <a href="/contact" class="btn-hero-primary">
          Ξεκινήστε το project σας
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="tel:6977383488" class="btn-hero-secondary">
          <Icon name="ic:baseline-phone" class="btn-hero-icon" />
          697 738 3488
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       BENTO GRID — Services + Stats
       ═══════════════════════════════════════════════ -->
  <section class="bento" id="services">
    <div class="container">
      <div class="bento__header reveal">
        <span class="eyebrow">Υπηρεσίες</span>
        <h2>Τα εργαλεία που χρειάζεστε, σε μια ομάδα.</h2>
      </div>

      <div class="bento__grid">
        <!-- CARD: E-shop — Large, spans 2 cols -->
        <a href="/ecommerce" class="bento__card bento__card--eshop reveal">
          <div class="bento__card-inner">
            <div class="bento__card-icon">
              <Icon name="ic:baseline-shopping-cart" />
            </div>
            <h3>E-shop Creation</h3>
            <p>Ηλεκτρονικά καταστήματα που μετατρέπουν επισκέπτες σε πελάτες. Shopify, WooCommerce ή custom — πάντα με focus στις πωλήσεις.</p>
            <ul class="bento__tags">
              <li>Shopify</li>
              <li>WooCommerce</li>
              <li>Mobile-first</li>
              <li>ERP σύνδεση</li>
            </ul>
          </div>
          <div class="bento__card-visual bento__card-visual--eshop">
            <div class="bento__mock-store">
              <div class="mock-product"></div>
              <div class="mock-product"></div>
              <div class="mock-product"></div>
              <div class="mock-product"></div>
              <div class="mock-product"></div>
              <div class="mock-product"></div>
            </div>
          </div>
        </a>

        <!-- CARD: Website — Large, spans 2 cols -->
        <a href="/istoselides-landingpage" class="bento__card bento__card--website reveal">
          <div class="bento__card-inner">
            <div class="bento__card-icon">
              <Icon name="ic:baseline-language" />
            </div>
            <h3>Website Building</h3>
            <p>Ultra-fast ιστοσελίδες με Astro & Next.js. Βέλτιστη SEO απόδοση, Core Web Vitals στο πράσινο.</p>
            <ul class="bento__tags">
              <li>Astro</li>
              <li>Next.js</li>
              <li>SEO</li>
              <li>Core Web Vitals</li>
            </ul>
          </div>
          <div class="bento__card-visual bento__card-visual--website">
            <div class="bento__mock-speed">
              <div class="speed-bar speed-bar--perf"><span>Performance</span><div class="speed-fill" style="width:98%">98</div></div>
              <div class="speed-bar speed-bar--seo"><span>SEO</span><div class="speed-fill" style="width:100%">100</div></div>
              <div class="speed-bar speed-bar--access"><span>Accessibility</span><div class="speed-fill" style="width:95%">95</div></div>
            </div>
          </div>
        </a>

        <!-- CARD: Web Apps — Medium -->
        <a href="/software-development" class="bento__card bento__card--apps reveal">
          <div class="bento__card-icon">
            <Icon name="ic:baseline-code" />
          </div>
          <h3>Custom Web Apps</h3>
          <p>Scalable SaaS & business tools. Αυτοματοποίηση, dashboards, API integrations.</p>
          <ul class="bento__tags">
            <li>React</li>
            <li>Node.js</li>
            <li>PostgreSQL</li>
          </ul>
        </a>

        <!-- CARD: Hosting — Medium -->
        <a href="/services#hosting" class="bento__card bento__card--hosting reveal">
          <div class="bento__card-icon">
            <Icon name="ic:baseline-cloud" />
          </div>
          <h3>Hosting & Maintenance</h3>
          <p>Managed cloud, SSL, backups, 24/7 υποστήριξη. Εμείς φροντίζουμε την τεχνολογία.</p>
          <ul class="bento__tags">
            <li>Cloud</li>
            <li>SSL</li>
            <li>Backups</li>
          </ul>
        </a>

        <!-- STAT CARDS — Small -->
        <div class="bento__card bento__card--stat bento__card--stat-1 reveal">
          <span class="stat-number">50+</span>
          <span class="stat-label">Projects</span>
        </div>
        <div class="bento__card bento__card--stat bento__card--stat-2 reveal">
          <span class="stat-number">10+</span>
          <span class="stat-label">Χρόνια</span>
        </div>
        <div class="bento__card bento__card--stat bento__card--stat-3 reveal">
          <span class="stat-number">24/7</span>
          <span class="stat-label">Support</span>
        </div>
        <div class="bento__card bento__card--stat bento__card--stat-4 reveal">
          <span class="stat-number">100%</span>
          <span class="stat-label">Αφοσίωση</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       PROCESS — How We Work (Bento row)
       ═══════════════════════════════════════════════ -->
  <section class="process">
    <div class="container">
      <div class="bento__header reveal">
        <span class="eyebrow">Διαδικασία</span>
        <h2>4 βήματα. Ένα αποτέλεσμα.</h2>
      </div>

      <div class="process__grid">
        <div class="process__card reveal">
          <span class="process__num">01</span>
          <h3>Ανακάλυψη</h3>
          <p>Κατανοούμε τους στόχους σας, αναλύουμε τον ανταγωνισμό, χαρτογραφούμε τις ανάγκες.</p>
        </div>
        <div class="process__card reveal">
          <span class="process__num">02</span>
          <h3>Σχεδιασμός</h3>
          <p>Wireframes, UI mockups, UX flows. Κάθε pixel έχει σκοπό — conversion, brand, εμπειρία.</p>
        </div>
        <div class="process__card reveal">
          <span class="process__num">03</span>
          <h3>Ανάπτυξη</h3>
          <p>Clean code, σύγχρονες τεχνολογίες, mobile-first. Σας ενημερώνουμε σε κάθε βήμα.</p>
        </div>
        <div class="process__card reveal">
          <span class="process__num">04</span>
          <h3>Launch & Grow</h3>
          <p>Go live, analytics, monitoring. Συνεχής βελτιστοποίηση και υποστήριξη μετά το launch.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       PORTFOLIO — Work Showcase
       ═══════════════════════════════════════════════ -->
  <section class="work">
    <div class="container">
      <div class="bento__header reveal">
        <span class="eyebrow">Portfolio</span>
        <h2>Δουλειές που μιλάνε μόνες τους.</h2>
      </div>

      <div class="work__grid">
        {projects.map((project) => (
          <div class="work__card reveal">
            <div class="work__thumb">
              <div class="work__placeholder">
                <Icon name="ic:baseline-image" class="work__placeholder-icon" />
              </div>
            </div>
            <div class="work__info">
              <h3>{project.name}</h3>
              <p>{project.description}</p>
              <div class="work__tags">
                {project.tags.map((tag) => (
                  <span class="work__tag">{tag}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="work__cta reveal">
        <a href="/portfolio" class="btn-outline">
          Όλα τα projects
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       TESTIMONIALS
       ═══════════════════════════════════════════════ -->
  <section class="reviews">
    <div class="container">
      <div class="bento__header reveal">
        <span class="eyebrow">Reviews</span>
        <h2>Τι λένε οι πελάτες μας.</h2>
      </div>

      <div class="reviews__grid">
        {testimonials.map((t) => (
          <div class="reviews__card reveal">
            <div class="reviews__stars">
              {Array.from({ length: t.rating }).map(() => (
                <svg width="14" height="14" viewBox="0 0 24 24" fill="var(--accent-amber)"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <blockquote>{t.quote}</blockquote>
            <div class="reviews__author">
              <div class="reviews__avatar">{t.name.charAt(0)}</div>
              <div>
                <strong>{t.name}</strong>
                <span>{t.company}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       TECH STACK — Logo Strip
       ═══════════════════════════════════════════════ -->
  <section class="tech">
    <div class="container">
      <p class="tech__label">Τεχνολογίες που χρησιμοποιούμε</p>
      <div class="tech__row">
        <div class="tech__item"><Icon name="mdi:react" /><span>React</span></div>
        <div class="tech__item"><Icon name="mdi:nodejs" /><span>Node.js</span></div>
        <div class="tech__item"><Icon name="mdi:language-typescript" /><span>TypeScript</span></div>
        <div class="tech__item"><Icon name="mdi:shopify" /><span>Shopify</span></div>
        <div class="tech__item"><Icon name="mdi:wordpress" /><span>WordPress</span></div>
        <div class="tech__item"><Icon name="mdi:cloud-outline" /><span>Cloud</span></div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       FAQ
       ═══════════════════════════════════════════════ -->
  <section class="faq">
    <div class="container">
      <div class="faq__layout">
        <div class="faq__left reveal">
          <span class="eyebrow">FAQ</span>
          <h2>Έχετε ερωτήσεις;<br/>Έχουμε απαντήσεις.</h2>
          <p>Δεν βρίσκετε αυτό που ψάχνετε; <a href="/contact" class="faq__contact-link">Επικοινωνήστε μαζί μας →</a></p>
        </div>
        <div class="faq__right">
          <details class="faq__item reveal">
            <summary>
              Πόσο κοστίζει η κατασκευή ενός e-shop;
              <span class="faq__chevron">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </summary>
            <p>Εξαρτάται από τις ανάγκες σας — αριθμός προϊόντων, integrations, custom features. Επικοινωνήστε μαζί μας για δωρεάν αξιολόγηση και προσφορά.</p>
          </details>
          <details class="faq__item reveal">
            <summary>
              Πόσο χρόνο χρειάζεται ένα project;
              <span class="faq__chevron">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </summary>
            <p>Website: 2-4 εβδομάδες. E-shop: 3-6 εβδομάδες. Custom app: 1-3 μήνες. Εξαρτάται από την πολυπλοκότητα.</p>
          </details>
          <details class="faq__item reveal">
            <summary>
              Παρέχετε υποστήριξη μετά την παράδοση;
              <span class="faq__chevron">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </summary>
            <p>Φυσικά. Πακέτα συντήρησης 24/7 — updates, backups, security monitoring, τεχνική βοήθεια.</p>
          </details>
          <details class="faq__item reveal">
            <summary>
              Μπορώ να διαχειρίζομαι μόνος μου το περιεχόμενο;
              <span class="faq__chevron">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </summary>
            <p>Ναι. Κάθε project παραδίδεται με εύχρηστο CMS ώστε να ενημερώνετε το περιεχόμενο εύκολα.</p>
          </details>
          <details class="faq__item reveal">
            <summary>
              Αναλαμβάνετε και SEO;
              <span class="faq__chevron">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </summary>
            <p>Κάθε project κατασκευάζεται με SEO best practices. Προσφέρουμε επίσης ολοκληρωμένες υπηρεσίες SEO — on-page, technical, link building.</p>
          </details>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       CTA — Final Call
       ═══════════════════════════════════════════════ -->
  <section class="final-cta">
    <div class="container">
      <div class="final-cta__card reveal">
        <span class="eyebrow eyebrow--light">Ξεκινήστε σήμερα</span>
        <h2>Έτοιμοι να κάνετε τη<br/>διαφορά online;</h2>
        <p>Η πρώτη συζήτηση είναι πάντα δωρεάν.</p>
        <div class="final-cta__actions">
          <a href="/contact" class="btn-cta-primary">
            Ζητήστε Δωρεάν Αξιολόγηση
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="tel:6977383488" class="btn-cta-phone">
            <Icon name="ic:baseline-phone" class="btn-cta-phone-icon" />
            697 738 3488
          </a>
        </div>
        <div class="final-cta__channels">
          <a href={`mailto:${site.contact.email}`}>{site.contact.email}</a>
          <span class="final-cta__sep">·</span>
          <a href="https://wa.me/306977383488" target="_blank" rel="noopener noreferrer">WhatsApp</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ═══════════════════════════════════════════
     UTILITIES
     ═══════════════════════════════════════════ */

  .eyebrow {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent-blue);
    margin-bottom: 0.6rem;
  }

  .eyebrow--light {
    color: rgba(255,255,255,0.6);
  }

  .bento__header {
    margin-bottom: 2.5rem;
  }

  .bento__header h2 {
    font-size: clamp(1.75rem, 3.5vw, 2.6rem);
    letter-spacing: -0.03em;
    line-height: 1.15;
    max-width: 560px;
  }

  .hide-mobile { display: inline; }

  /* ═══════════════════════════════════════════
     HERO
     ═══════════════════════════════════════════ */

  .hero {
    padding: calc(var(--navbar-height) + 4rem) 0 3.5rem;
  }

  .hero__container {
    max-width: 780px;
  }

  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.9rem 0.4rem 0.65rem;
    background: var(--theme-surface-1);
    border: 1px solid var(--theme-surface-2);
    border-radius: 100px;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--theme-on-bg);
    margin-bottom: 1.75rem;
  }

  .hero__badge-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent-emerald);
    box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.2);
  }

  .hero__title {
    font-size: clamp(2.6rem, 6vw, 4.5rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.05;
    color: var(--theme-on-bg);
    margin-bottom: 1.25rem;
  }

  .hero__title em {
    font-style: normal;
    background: linear-gradient(135deg, var(--accent-blue), var(--accent-violet));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero__sub {
    font-size: 1.15rem;
    line-height: 1.65;
    color: var(--theme-on-bg);
    opacity: 0.5;
    margin-bottom: 2rem;
  }

  .hero__cta {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .btn-hero-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 1.75rem;
    background: var(--theme-on-bg);
    color: var(--theme-bg);
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.95rem;
    transition: var(--theme-transition);
  }

  .btn-hero-primary:hover {
    opacity: 0.85;
    transform: translateY(-1px);
  }

  .btn-hero-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--theme-on-bg);
    opacity: 0.5;
    transition: var(--theme-transition);
  }

  .btn-hero-secondary:hover {
    opacity: 0.8;
  }

  .btn-hero-icon {
    width: 18px;
    height: 18px;
  }

  /* ═══════════════════════════════════════════
     BENTO GRID
     ═══════════════════════════════════════════ */

  .bento {
    padding: 5rem 0;
  }

  .bento__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: auto auto auto;
    gap: 1rem;
  }

  .bento__card {
    border-radius: 16px;
    padding: 1.75rem;
    text-decoration: none;
    color: inherit;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    overflow: hidden;
    position: relative;
  }

  .bento__card:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.08);
  }

  .bento__card h3 {
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
  }

  .bento__card p {
    font-size: 0.88rem;
    line-height: 1.6;
    opacity: 0.7;
  }

  .bento__card-icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    margin-bottom: 1rem;
    background: rgba(255,255,255,0.5);
  }

  .bento__card-icon svg,
  .bento__card-icon [data-icon] {
    width: 22px;
    height: 22px;
  }

  .bento__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    list-style: none;
    margin-top: 0.85rem;
  }

  .bento__tags li {
    padding: 0.2rem 0.55rem;
    background: rgba(255,255,255,0.45);
    border-radius: 6px;
    font-size: 0.72rem;
    font-weight: 600;
    opacity: 0.65;
  }

  /* — Large cards (span 2 cols) — */
  .bento__card--eshop,
  .bento__card--website {
    grid-column: span 2;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    min-height: 260px;
  }

  .bento__card--eshop {
    background: linear-gradient(145deg, #ecfdf5 0%, #d1fae5 100%);
    color: #064e3b;
  }

  .bento__card--eshop .bento__card-icon {
    color: #059669;
    background: rgba(5, 150, 105, 0.12);
  }

  .bento__card--website {
    background: linear-gradient(145deg, #eff6ff 0%, #dbeafe 100%);
    color: #1e3a5f;
  }

  .bento__card--website .bento__card-icon {
    color: #2563eb;
    background: rgba(37, 99, 235, 0.12);
  }

  /* — Medium cards — */
  .bento__card--apps {
    grid-column: span 2;
    background: linear-gradient(145deg, #f5f3ff 0%, #ede9fe 100%);
    color: #3b1f6e;
  }

  .bento__card--apps .bento__card-icon {
    color: #7c3aed;
    background: rgba(124, 58, 237, 0.12);
  }

  .bento__card--hosting {
    grid-column: span 2;
    background: linear-gradient(145deg, #fffbeb 0%, #fef3c7 100%);
    color: #78350f;
  }

