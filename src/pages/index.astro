---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServicesGrid from '../components/ServicesGrid.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { Icon } from 'astro-icon/components';
import { services } from '../data/services';
import { site } from '../data/site';
import { projects } from '../data/portfolio';
import { testimonials } from '../data/testimonials';
import { footerSocials } from '../config/footer';
---

<BaseLayout
  title={`${site.name} | E-shop, Websites, Custom Apps`}
  description="Phpixel — Κατασκευή e-shop, ιστοσελίδων, custom web apps, hosting & maintenance. Ολοκληρωμένες ψηφιακές λύσεις."
  darkHero={true}
>

  <!-- ========== HERO SECTION ========== -->
  <section class="hero">
    <div class="hero__bg"></div>
    <div class="container hero__inner">
      <div class="hero__content">
        <span class="hero__badge">From idea to pixel and code</span>
        <h1 class="hero__title">
          Αυξήστε τις Πωλήσεις σας<br />
          <span class="hero__title-accent">με Ψηφιακές Λύσεις που Δουλεύουν</span>
        </h1>
        <p class="hero__subtitle">
          E-shop, websites, custom apps & hosting. Δημιουργούμε ψηφιακές λύσεις
          που φέρνουν μετρήσιμα αποτελέσματα για την επιχείρησή σας.
        </p>
        <div class="hero__actions">
          <a href="/contact" class="btn btn--primary btn--lg">
            <Icon name="ic:baseline-mail" class="btn-icon" />
            Ζητήστε Δωρεάν Αξιολόγηση
          </a>
          <a href="#services" class="btn btn--outline btn--lg hero__outline-btn">
            Οι υπηρεσίες μας
            <Icon name="ic:baseline-arrow-forward" class="btn-icon" />
          </a>
        </div>
        <a href="tel:6977383488" class="hero__phone">
          <Icon name="ic:baseline-phone" class="hero__phone-icon" />
          697 738 3488
        </a>
        <div class="hero__proof">
          <span class="hero__proof-item">50+ projects</span>
          <span class="hero__proof-sep">|</span>
          <span class="hero__proof-item">10+ χρόνια εμπειρίας</span>
          <span class="hero__proof-sep">|</span>
          <span class="hero__proof-item">100% αφοσίωση</span>
        </div>
      </div>

      <div class="hero__visual">
        <div class="hero__card hero__card--1">
          <Icon name="ic:baseline-shopping-cart" class="hero-card-icon" />
          <span>E-shop</span>
        </div>
        <div class="hero__card hero__card--2">
          <Icon name="ic:baseline-language" class="hero-card-icon" />
          <span>Websites</span>
        </div>
        <div class="hero__card hero__card--3">
          <Icon name="ic:baseline-code" class="hero-card-icon" />
          <span>Web Apps</span>
        </div>
        <div class="hero__card hero__card--4">
          <Icon name="ic:baseline-cloud" class="hero-card-icon" />
          <span>Hosting</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== SERVICES GRID ========== -->
  <section id="services">
    <ServicesGrid services={services} title="Τι Κάνουμε" subtitle="What We Do" />
  </section>

  <!-- ========== PORTFOLIO SECTION ========== -->
  <!-- TODO: Replace placeholder images and data with real project screenshots -->
  <section class="portfolio">
    <div class="container">
      <div class="reveal">
        <SectionHeader title="Δουλειές μας" subtitle="Our Work">
          Δείτε μερικά από τα projects που έχουμε υλοποιήσει για πελάτες μας.
        </SectionHeader>
      </div>

      <div class="portfolio__grid">
        {projects.map((project, i) => (
          <div class="portfolio__card reveal" style={`transition-delay: ${i * 0.1}s`}>
            <!-- TODO: Replace with real project screenshot -->
            <div class="portfolio__thumb">
              <div class="portfolio__placeholder">
                <Icon name="ic:baseline-image" class="portfolio__placeholder-icon" />
              </div>
              <div class="portfolio__overlay">
                <a href="/portfolio" class="portfolio__link">Δες περισσότερα</a>
              </div>
            </div>
            <div class="portfolio__info">
              <h3 class="portfolio__name">{project.name}</h3>
              <p class="portfolio__desc">{project.description}</p>
              <div class="portfolio__tags">
                {project.tags.map((tag) => (
                  <span class="portfolio__tag">{tag}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="portfolio__cta reveal">
        <a href="/portfolio" class="btn btn--outline btn--lg">
          Δες όλα τα projects μας
          <Icon name="ic:baseline-arrow-forward" class="btn-icon" />
        </a>
      </div>
    </div>
  </section>

  <!-- ========== TESTIMONIALS SECTION ========== -->
  <!-- TODO: Replace placeholder testimonials with real client reviews -->
  <section class="testimonials">
    <div class="container">
      <div class="reveal">
        <SectionHeader title="Τι Λένε οι Πελάτες μας" subtitle="Testimonials">
          Η εμπιστοσύνη των πελατών μας είναι η καλύτερη επιβράβευση.
        </SectionHeader>
      </div>

      <div class="testimonials__grid">
        {testimonials.map((t, i) => (
          <div class="testimonials__card reveal" style={`transition-delay: ${i * 0.1}s`}>
            <div class="testimonials__stars">
              {Array.from({ length: t.rating }).map(() => (
                <Icon name="ic:baseline-star" class="testimonials__star" />
              ))}
            </div>
            <blockquote class="testimonials__quote">
              &ldquo;{t.quote}&rdquo;
            </blockquote>
            <div class="testimonials__author">
              <div class="testimonials__avatar">
                {t.name.charAt(0)}
              </div>
              <div>
                <div class="testimonials__name">{t.name}</div>
                <div class="testimonials__company">{t.company}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== WHY US SECTION ========== -->
  <section class="why-us">
    <div class="container">
      <div class="reveal">
        <SectionHeader title="Η Προσέγγισή μας" subtitle="Our Approach">
          Συνδυάζουμε τεχνολογία, σχεδιασμό και στρατηγική
          για να φτιάξουμε κάτι που πραγματικά δουλεύει.
        </SectionHeader>
      </div>

      <div class="why-us__grid">
        <div class="why-us__item reveal">
          <div class="why-us__number">01</div>
          <h3>Σύγχρονη Τεχνολογία</h3>
          <p>Astro, Next.js, React, Shopify — χρησιμοποιούμε τις πιο σύγχρονες τεχνολογίες για ταχύτητα και απόδοση.</p>
        </div>
        <div class="why-us__item reveal" style="transition-delay: 0.1s">
          <div class="why-us__number">02</div>
          <h3>Σχεδιασμός με Προτεραιότητα στο SEO</h3>
          <p>Κάθε σελίδα βελτιστοποιημένη για τις μηχανές αναζήτησης. Core Web Vitals, semantic HTML, structured data.</p>
        </div>
        <div class="why-us__item reveal" style="transition-delay: 0.2s">
          <div class="why-us__number">03</div>
          <h3>Συνεχής Υποστήριξη</h3>
          <p>Δεν σε αφήνουμε μετά το launch. Συνεχής υποστήριξη, updates και monitoring 24/7.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== CONTACT FORM SECTION ========== -->
  <section class="contact-section">
    <div class="container">
      <div class="reveal">
        <SectionHeader title="Ας δημιουργήσουμε κάτι μαζί" subtitle="Επικοινωνία" light={true}>
          Μην διστάσετε να επικοινωνήσετε μαζί μας. Η ιδέα σας αξίζει να γίνει πραγματικότητα.
        </SectionHeader>
      </div>

      <div class="contact__grid">
        <!-- Left Column: Contact Info -->
        <div class="contact__info reveal">
          <div class="contact__info-item">
            <Icon name="ic:baseline-phone" class="contact__info-icon" />
            <div>
              <span class="contact__info-label">Τηλέφωνο</span>
              <a href="tel:6977383488" class="contact__info-value">697 738 3488</a>
            </div>
          </div>
          <div class="contact__info-item">
            <Icon name="ic:baseline-mail" class="contact__info-icon" />
            <div>
              <span class="contact__info-label">Email</span>
              <a href={`mailto:${site.contact.email}`} class="contact__info-value">{site.contact.email}</a>
            </div>
          </div>
          <div class="contact__socials">
            {footerSocials.map((social) => (
              <a href={social.url} target="_blank" rel="noopener noreferrer" aria-label={social.name} class="contact__social-link">
                <Icon name={social.icon} />
              </a>
            ))}
          </div>
          <p class="contact__free-note">Η πρώτη συζήτηση είναι πάντα δωρεάν</p>
        </div>

        <!-- Right Column: Inline Form -->
        <form class="contact__form reveal" style="transition-delay: 0.1s" method="POST" action="/api/contact">
          <div class="form__field">
            <label for="name" class="form__label">Ονοματεπώνυμο</label>
            <input type="text" id="name" name="name" required class="form__input" placeholder="Το όνομά σας" />
          </div>
          <div class="form__field">
            <label for="contact-info" class="form__label">Email ή Τηλέφωνο</label>
            <input type="text" id="contact-info" name="contactInfo" required class="form__input" placeholder="email@example.com ή 69xxxxxxxx" />
          </div>
          <div class="form__field">
            <label for="service" class="form__label">Τι χρειάζεστε;</label>
            <select id="service" name="service" class="form__select">
              <option value="">Επιλέξτε υπηρεσία</option>
              <option value="eshop">E-shop</option>
              <option value="website">Ιστοσελίδα</option>
              <option value="webapp">Web App</option>
              <option value="hosting">Hosting</option>
              <option value="other">Άλλο</option>
            </select>
          </div>
          <div class="form__field">
            <label for="message" class="form__label">Μήνυμα</label>
            <textarea id="message" name="message" rows="3" class="form__textarea" placeholder="Πείτε μας λίγα λόγια για το project σας..."></textarea>
          </div>
          <button type="submit" class="btn btn--primary btn--lg form__submit">
            <Icon name="ic:baseline-send" class="btn-icon" />
            Στείλε Μήνυμα
          </button>
          <p class="form__privacy">
            Τα δεδομένα σας είναι ασφαλή. <a href="/legal">Πολιτική Απορρήτου</a>
          </p>
        </form>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ========================================
     HERO
     ======================================== */

  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-top: var(--navbar-height);
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    background: var(--gradient-hero);
    z-index: 0;
  }

  .hero__bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 20% 50%, rgba(59, 130, 246, 0.15) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 50%, rgba(139, 92, 246, 0.1) 0%, transparent 60%);
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    align-items: center;
    gap: 3rem;
    padding: 2rem var(--container-padding);
  }

  .hero__content {
    color: #fff;
  }

  .hero__badge {
    display: inline-block;
    padding: 0.4rem 1rem;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 2rem;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    margin-bottom: 1.25rem;
    backdrop-filter: blur(8px);
  }

  .hero__title {
    color: #fff;
    margin-bottom: 1rem;
    font-size: clamp(1.8rem, 4vw, 3.2rem);
  }

  .hero__title-accent {
    background: var(--gradient-accent);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero__subtitle {
    font-size: 1.1rem;
    opacity: 0.8;
    line-height: 1.7;
    max-width: 520px;
    margin-bottom: 1.5rem;
  }

  .hero__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
  }

  .hero__outline-btn {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.3);
  }

  .hero__outline-btn:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.5);
    color: #fff;
  }

  .btn-icon {
    width: 20px;
    height: 20px;
  }

  .hero__phone {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #fff;
    font-weight: 600;
    font-size: 1.05rem;
    padding: 0.5rem 0;
    margin-bottom: 1.25rem;
    opacity: 0.9;
    transition: var(--theme-transition);
  }

  .hero__phone:hover {
    opacity: 1;
  }

  .hero__phone-icon {
    width: 20px;
    height: 20px;
  }

  .hero__proof {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    font-size: 0.85rem;
    opacity: 0.6;
    color: #fff;
  }

  .hero__proof-sep {
    opacity: 0.4;
  }

  /* Hero Visual — Floating Cards */
  .hero__visual {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    padding: 1rem;
  }

  .hero__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    padding: 1.5rem 1rem;
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--theme-shape-radius);
    color: #fff;
    font-weight: 600;
    font-size: 0.9rem;
    transition: var(--theme-transition);
    animation: float 6s ease-in-out infinite;
  }

  .hero__card:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.2);
    transform: translateY(-4px);
  }

  .hero__card--1 { animation-delay: 0s; }
  .hero__card--2 { animation-delay: 1.5s; }
  .hero__card--3 { animation-delay: 3s; }
  .hero__card--4 { animation-delay: 4.5s; }

  .hero-card-icon {
    width: 32px;
    height: 32px;
    opacity: 0.9;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  /* ========================================
     PORTFOLIO
     ======================================== */

  .portfolio {
    padding: var(--section-padding);
  }

  .portfolio__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--theme-grid-gap);
  }

  .portfolio__card {
    background: var(--theme-surface-1);
    border-radius: var(--theme-shape-radius);
    overflow: hidden;
    transition: var(--theme-transition);
    border: 1px solid transparent;
  }

  .portfolio__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.1);
    border-color: var(--accent-blue);
  }

  .portfolio__thumb {
    position: relative;
    aspect-ratio: 16 / 10;
    background: var(--theme-surface-2);
    overflow: hidden;
  }

  .portfolio__placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--theme-surface-2) 0%, var(--theme-surface-1) 100%);
  }

  .portfolio__placeholder-icon {
    width: 48px;
    height: 48px;
    opacity: 0.3;
  }

  .portfolio__overlay {
    position: absolute;
    inset: 0;
    background: rgba(10, 10, 10, 0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: var(--theme-transition);
  }

  .portfolio__card:hover .portfolio__overlay {
    opacity: 1;
  }

  .portfolio__link {
    color: #fff;
    font-weight: 600;
    padding: 0.6rem 1.5rem;
    border: 2px solid #fff;
    border-radius: var(--button-border-radius);
    transition: var(--theme-transition);
  }

  .portfolio__link:hover {
    background: #fff;
    color: var(--theme-primary);
  }

  .portfolio__info {
    padding: 1.25rem 1.5rem;
  }

  .portfolio__name {
    font-size: 1.1rem;
    margin-bottom: 0.35rem;
  }

  .portfolio__desc {
    font-size: 0.9rem;
    opacity: 0.7;
    margin-bottom: 0.75rem;
    line-height: 1.5;
  }

  .portfolio__tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .portfolio__tag {
    display: inline-block;
    padding: 0.2rem 0.65rem;
    background: var(--gradient-subtle);
    border: 1px solid var(--glass-border);
    border-radius: 2rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent-blue);
  }

  .portfolio__cta {
    text-align: center;
    margin-top: 2.5rem;
  }

  /* ========================================
     TESTIMONIALS
     ======================================== */

  .testimonials {
    padding: var(--section-padding);
    background: var(--theme-surface-1);
  }

  .testimonials__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--theme-grid-gap);
  }

  .testimonials__card {
    background: #fff;
    padding: 2rem;
    border-radius: var(--theme-shape-radius);
    border: 1px solid var(--glass-border);
    transition: var(--theme-transition);
  }

  .testimonials__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.08);
  }

  .testimonials__stars {
    display: flex;
    gap: 0.15rem;
    margin-bottom: 1rem;
  }

  .testimonials__star {
    width: 20px;
    height: 20px;
    color: var(--accent-amber);
  }

  .testimonials__quote {
    font-size: 0.95rem;
    line-height: 1.7;
    opacity: 0.8;
    margin-bottom: 1.5rem;
    font-style: italic;
  }

  .testimonials__author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .testimonials__avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--gradient-accent);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1.1rem;
    flex-shrink: 0;
  }

  .testimonials__name {
    font-weight: 700;
    font-size: 0.95rem;
  }

  .testimonials__company {
    font-size: 0.8rem;
    opacity: 0.6;
  }

  /* ========================================
     WHY US SECTION
     ======================================== */

  .why-us {
    padding: var(--section-padding);
  }

  .why-us__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .why-us__item {
    padding: 2rem;
  }

  .why-us__number {
    font-family: var(--font-heading);
    font-size: 3rem;
    font-weight: 900;
    background: var(--gradient-accent);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
    margin-bottom: 1rem;
  }

  .why-us__item h3 {
    margin-bottom: 0.75rem;
  }

  .why-us__item p {
    font-size: 0.95rem;
    opacity: 0.7;
    line-height: 1.65;
  }

  /* ========================================
     CONTACT SECTION
     ======================================== */

  .contact-section {
    padding: var(--section-padding);
    background: var(--gradient-hero);
    color: #fff;
  }

  .contact__grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 3rem;
    align-items: start;
  }

  .contact__info-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .contact__info-icon {
    width: 24px;
    height: 24px;
    opacity: 0.8;
    flex-shrink: 0;
  }

  .contact__info-label {
    display: block;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.5;
    margin-bottom: 0.15rem;
  }

  .contact__info-value {
    font-size: 1.05rem;
    font-weight: 600;
    color: #fff;
    transition: var(--theme-transition);
  }

  .contact__info-value:hover {
    opacity: 0.8;
  }

  .contact__socials {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    margin-top: 0.5rem;
  }

  .contact__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
    transition: var(--theme-transition);
    color: #fff;
  }

  .contact__social-link:hover {
    background: rgba(255, 255, 255, 0.2);
    transform: translateY(-2px);
  }

  .contact__social-link svg {
    width: 20px;
    height: 20px;
  }

  .contact__free-note {
    font-size: 0.9rem;
    opacity: 0.6;
    font-style: italic;
  }

  /* Contact Form */
  .contact__form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form__field {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .form__label {
    font-size: 0.85rem;
    font-weight: 600;
    opacity: 0.9;
  }

  .form__input,
  .form__select,
  .form__textarea {
    padding: 0.75rem 1rem;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: var(--theme-shape-radius-sm);
    color: #fff;
    font-family: var(--font-body);
    font-size: 0.95rem;
    transition: var(--theme-transition);
  }

  .form__input::placeholder,
  .form__textarea::placeholder {
    color: rgba(255, 255, 255, 0.35);
  }

