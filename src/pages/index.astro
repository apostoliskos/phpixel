---
// Στατική σελίδα — μπαίνει στο sitemap και σερβίρεται prerendered
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
import { site } from '../data/site';
import { projects } from '../data/portfolio';
import { testimonials } from '../data/testimonials';
import { SHOW_TESTIMONIALS } from '../config';
import FaqSection from '../components/FaqSection.astro';
import WebSiteSchema from '../components/schema/WebSiteSchema.astro';
import { publicImageExists } from '../utils/publicImages';

const services = [
  {
    icon: 'ic:baseline-shopping-cart',
    title: 'Κατασκευή E-shop',
    href: '/kataskevi-eshop',
    desc: 'Ηλεκτρονικά καταστήματα που μετατρέπουν επισκέπτες σε πελάτες. WooCommerce ή custom κατασκευή: διαλέγουμε ό,τι ταιριάζει στο προϊόν σου, όχι ό,τι μας βολεύει.',
    chips: ['WooCommerce', 'Custom', 'ERP', 'B2C & B2B'],
    variant: 'eshop',
  },
  {
    icon: 'ic:baseline-language',
    title: 'Ιστοσελίδες & Landing Pages',
    href: '/kataskevi-istoselidon',
    desc: 'Γρήγορες, καθαρές σελίδες που εξηγούν τι κάνεις και γιατί να σε διαλέξουν. Φτιαγμένες για να τις βρίσκει η Google.',
    chips: ['Ταχύτητα', 'SEO-ready', 'Custom design'],
    variant: 'website',
  },
  {
    icon: 'ic:baseline-search',
    title: 'SEO & AEO',
    href: '/seo',
    desc: 'Να σε βρίσκουν όσοι σε ψάχνουν, στην Google και στα AI εργαλεία που πλέον προτείνουν προϊόντα και επιχειρήσεις.',
    chips: ['On-page', 'Technical', 'AEO/GEO'],
    variant: 'seo',
  },
  {
    icon: 'ic:baseline-mail',
    title: 'Email Marketing',
    href: '/email-marketing',
    desc: 'Αυτόματα emails που φέρνουν πελάτες πίσω: εγκαταλελειμμένα καλάθια, newsletters, follow-ups. Δουλεύουν κι όταν κοιμάσαι.',
    chips: ['Flows', 'Καλάθια', 'Newsletters'],
    variant: 'email',
  },
  {
    icon: 'ic:baseline-ads-click',
    title: 'Google Ads & Social',
    href: '/diafimisi',
    desc: 'Διαφήμιση με μετρήσιμο αποτέλεσμα. Ξέρεις τι ξοδεύεις και τι σου φέρνει πίσω.',
    chips: ['Google Ads', 'Meta', 'Reporting'],
    variant: 'ads',
  },
  {
    icon: 'ic:baseline-code',
    title: 'Custom Εφαρμογές',
    href: '/software-development',
    desc: 'Όταν τα έτοιμα δεν φτάνουν: εφαρμογές, dashboards και συνδέσεις με ERP, φτιαγμένα στα μέτρα σου.',
    chips: ['Αυτοματισμοί', 'API', 'Dashboards'],
    variant: 'apps',
  },
];

const processSteps = [
  {
    num: '01',
    title: 'Γνωριμία',
    desc: 'Μιλάμε για τους στόχους σου, βλέπουμε τον ανταγωνισμό και καταλαβαίνουμε τι πραγματικά χρειάζεσαι και τι όχι.',
  },
  {
    num: '02',
    title: 'Σχεδιασμός',
    desc: 'Wireframes και σχέδια πριν γραφτεί γραμμή κώδικα. Ξέρεις τι θα πάρεις πριν ξεκινήσουμε.',
  },
  {
    num: '03',
    title: 'Κατασκευή',
    desc: 'Καθαρός κώδικας, πρώτα το κινητό. Βλέπεις την πρόοδο σε κάθε βήμα, χωρίς εκπλήξεις στο τέλος.',
  },
  {
    num: '04',
    title: 'Launch & μετά',
    desc: 'Βγαίνουμε live, στήνουμε analytics και δεν εξαφανιζόμαστε. Το site σου έχει άνθρωπο.',
  },
];

const faqItems = [
  {
    q: 'Πόσο κοστίζει ένα e-shop;',
    a: 'Εξαρτάται από το τι χρειάζεσαι: πόσα προϊόντα έχεις, αν θες σύνδεση με ERP, courier ή Skroutz, πόσο custom θα είναι ο σχεδιασμός. Στην ελληνική αγορά οι τιμές έχουν τεράστιο εύρος, γι’ αυτό δεν πετάμε νούμερα στα τυφλά. Θα δούμε μαζί τι πραγματικά χρειάζεσαι (και τι όχι) και θα πάρεις αναλυτική προσφορά χωρίς κρυφά κόστη. Η πρώτη κουβέντα δεν σε δεσμεύει σε τίποτα.',
  },
  {
    q: 'Σε πόσο καιρό θα είναι έτοιμο;',
    a: 'Ιστοσελίδα: συνήθως 2–4 εβδομάδες. E-shop: 3–6 εβδομάδες. Custom εφαρμογή: 1–3 μήνες. Θα σου πούμε ρεαλιστικό χρονοδιάγραμμα από την αρχή, όχι αυτό που θες να ακούσεις.',
  },
  {
    q: 'Θα μπορώ να διαχειρίζομαι μόνος μου το περιεχόμενο;',
    a: 'Ναι. Κάθε site παραδίδεται με εύχρηστο σύστημα διαχείρισης και θα σου δείξουμε πώς να αλλάζεις προϊόντα, τιμές και κείμενα μόνος σου. Κι αν κολλήσεις, είμαστε ένα μήνυμα μακριά.',
  },
  {
    q: 'Έχω ήδη e-shop που δεν αποδίδει. Το αναλαμβάνετε;',
    a: 'Ναι, και είναι από τις πιο συχνές δουλειές μας. Ξεκινάμε με έναν έλεγχο σε ταχύτητα, SEO και εμπειρία αγοράς, και σου λέμε τι φταίει και τι αξίζει να διορθωθεί. Καμιά φορά δεν χρειάζεσαι καινούριο site, χρειάζεσαι το σωστό χέρι στο υπάρχον.',
  },
  {
    q: 'Συνδέεται το e-shop με το ERP ή το λογιστικό μου;',
    a: 'Ναι. Στήνουμε αυτόματο συγχρονισμό προϊόντων, αποθεμάτων και παραγγελιών με το ERP σου, καθώς και συνδέσεις με courier, τρόπους πληρωμής και πλατφόρμες όπως το Skroutz.',
  },
  {
    q: 'Τι γίνεται μετά το launch;',
    a: 'Δεν εξαφανιζόμαστε. Αναλαμβάνουμε τη φροντίδα του site (ενημερώσεις, backups, ασφάλεια, φιλοξενία) με πακέτα υποστήριξης, ώστε να έχεις πάντα έναν άνθρωπο να παίρνει τηλέφωνο.',
  },
  {
    q: 'Κάνετε SEO;',
    a: 'Κάθε site που φτιάχνουμε έχει γερές βάσεις SEO από την πρώτη μέρα. Προσφέρουμε και συνεχές SEO ως υπηρεσία, μαζί με βελτιστοποίηση για τις AI μηχανές αναζήτησης (AEO/GEO), εκεί όπου ψάχνουν όλο και περισσότεροι πελάτες σήμερα.',
  },
  {
    q: 'Πού βρίσκεστε; Δουλεύετε πανελλαδικά;',
    a: 'Η έδρα μας είναι στην Ελλάδα και δουλεύουμε με επιχειρήσεις σε όλη τη χώρα. Τα περισσότερα projects τρέχουν εξ ολοκλήρου online: κλήσεις, preview links, καθημερινή επικοινωνία.',
  },
];

const heroImage = '/images/hero-devices.webp';
const heroImageExists = publicImageExists(heroImage);
---

<BaseLayout
  title="Κατασκευή E-shop & Ιστοσελίδων που Πουλάνε | phpixel"
  description="Κατασκευή e-shop με WooCommerce ή custom, ιστοσελίδες, SEO και email marketing. Δουλεύουμε με επιχειρήσεις σε όλη την Ελλάδα. Μιλάς με αυτόν που γράφει τον κώδικα."
>
  <WebSiteSchema />

  <!-- ═══════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════ -->
  <section class="hero">
    <div class="container hero__container">
      <h1 class="hero__title reveal">
        Φτιάχνουμε e-shop και<br/>
        ιστοσελίδες που <em>πουλάνε</em>.
      </h1>
      <p class="hero__sub reveal">
        Από την ιδέα μέχρι την πρώτη παραγγελία, και μετά. Σχεδιάζουμε, στήνουμε
        και φροντίζουμε την online παρουσία σου, για να ασχολείσαι εσύ με αυτό που
        ξέρεις καλύτερα: την επιχείρησή σου.
      </p>
      <div class="hero__cta reveal">
        <a href="/contact" class="btn-hero-primary">
          Πες μας για το project σου
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="/portfolio" class="btn-hero-secondary">
          Δες τις δουλειές μας →
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SERVICES + STATS
       ═══════════════════════════════════════════════ -->
  <section class="bento" id="services">
    <div class="container">
      <div class="bento__header reveal">
        <span class="eyebrow">Υπηρεσίες</span>
        <h2>Ό,τι χρειάζεσαι για να πουλάς online.</h2>
      </div>

      <div class="bento__grid">
        {services.map((s) => (
          <a href={s.href} class={`bento__card bento__card--${s.variant} reveal`}>
            <div class="bento__card-icon">
              <Icon name={s.icon} />
            </div>
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
            <ul class="bento__tags">
              {s.chips.map((chip) => (
                <li>{chip}</li>
              ))}
            </ul>
          </a>
        ))}
      </div>

      <!-- Stats row -->
      <div class="stats__row">
        <div class="stats__item reveal">
          <Icon name="ic:baseline-storefront" class="stats__icon" />
          <span>10+ χρόνια στο e-commerce</span>
        </div>
        <div class="stats__item reveal">
          <Icon name="ic:baseline-code" class="stats__icon" />
          <span>Μιλάς με αυτόν που γράφει τον κώδικα</span>
        </div>
        <div class="stats__item reveal">
          <Icon name="ic:baseline-receipt-long" class="stats__icon" />
          <span>Προσφορά χωρίς κρυφά κόστη</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       PROCESS — How We Work
       ═══════════════════════════════════════════════ -->
  <section class="process">
    <div class="container">
      <div class="bento__header reveal">
        <span class="eyebrow">Διαδικασία</span>
        <h2>Η διαδικασία, με μια ματιά.</h2>
      </div>

      <div class="process__grid">
        {processSteps.map((step) => (
          <div class="process__card reveal">
            <span class="process__num">{step.num}</span>
            <h3>{step.title}</h3>
            <p>{step.desc}</p>
          </div>
        ))}
      </div>

      <div class="process__cta reveal">
        <a href="/how-we-work" class="btn-outline">
          Δες αναλυτικά πώς δουλεύουμε
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       PORTFOLIO — Work Showcase
       ═══════════════════════════════════════════════ -->
  <section class="work">
    <div class="container">
      <div class="bento__header reveal">
        <span class="eyebrow">Portfolio</span>
        <h2>Δουλειές που μιλάνε μόνες τους.</h2>
      </div>

      {heroImageExists ? (
        <img
          src={heroImage}
          alt="E-shop και ιστοσελίδες κατασκευασμένα από την phpixel"
          width="1600"
          height="1200"
          loading="lazy"
          decoding="async"
          class="work__intro-img reveal"
        />
      ) : null}

      <div class="work__grid">
        {projects.map((project) => {
          const src =
            project.image && publicImageExists(project.image)
              ? project.image
              : publicImageExists(project.thumb)
                ? project.thumb
                : null;
          return (
            <div class="work__card reveal">
              <div class="work__thumb">
                {src ? (
                  <img
                    src={src}
                    alt={project.imageAlt ?? `Screenshot: ${project.name}`}
                    width="1200"
                    height="900"
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <div class="work__placeholder">
                    <Icon name="ic:baseline-image" class="work__placeholder-icon" />
                  </div>
                )}
              </div>
              <div class="work__info">
                <h3>{project.name}</h3>
                <p>{project.description}</p>
                <div class="work__tags">
                  {project.tags.map((tag) => (
                    <span class="work__tag">{tag}</span>
                  ))}
                </div>
              </div>
            </div>
          );
        })}
      </div>

      <div class="work__cta reveal">
        <a href="/portfolio" class="btn-outline">
          Όλα τα projects
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       TESTIMONIALS — hidden until real quotes exist
       ═══════════════════════════════════════════════ -->
  {SHOW_TESTIMONIALS && (
    <section class="reviews">
      <div class="container">
        <div class="bento__header reveal">
          <span class="eyebrow">Reviews</span>
          <h2>Τι λένε οι πελάτες μας.</h2>
        </div>

        <div class="reviews__grid">
          {testimonials.map((t) => (
            <div class="reviews__card reveal">
              <div class="reviews__stars">
                {Array.from({ length: t.rating }).map(() => (
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="var(--accent-amber)"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                ))}
              </div>
              <blockquote>{t.quote}</blockquote>
              <div class="reviews__author">
                <div class="reviews__avatar">{t.name.charAt(0)}</div>
                <div>
                  <strong>{t.name}</strong>
                  <span>{t.company}</span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ═══════════════════════════════════════════════
       TECH STRIP
       ═══════════════════════════════════════════════ -->
  <section class="tech">
    <div class="container">
      <p class="tech__line">
        Δουλεύουμε με WordPress, WooCommerce, CS-Cart, Astro, React και Node.js. Αλλά το εργαλείο δεν κάνει
        τη δουλειά. Ο τρόπος που το χρησιμοποιείς, ναι. Γι' αυτό δεν διαλέγουμε τεχνολογίες από συνήθεια,
        διαλέγουμε ό,τι ταιριάζει στο δικό σου έργο.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       FAQ (με FAQPage schema)
       ═══════════════════════════════════════════════ -->
  <FaqSection items={faqItems} label="FAQ" title="Έχεις ερωτήσεις; Έχουμε απαντήσεις." />

</BaseLayout>

<style>
  /* ═══════════════════════════════════════════
     UTILITIES
     ═══════════════════════════════════════════ */

  .eyebrow {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    /* Σκουρύνουμε ελαφρά το accent για επαρκές contrast (WCAG AA) στο μικρό μέγεθος */
    color: color-mix(in srgb, var(--accent-blue) 72%, #000);
    margin-bottom: 0.6rem;
  }

  .bento__header {
    margin-bottom: 2.5rem;
  }

  .bento__header h2 {
    font-size: clamp(1.75rem, 3.5vw, 2.6rem);
    letter-spacing: -0.03em;
    line-height: 1.15;
    max-width: 560px;
  }

  .hide-mobile { display: inline; }

  /* ═══════════════════════════════════════════
     HERO
     ═══════════════════════════════════════════ */

  .hero {
    padding: calc(var(--navbar-height) + 4rem) 0 3.5rem;
  }

  .hero__container {
    max-width: 780px;
  }

  .hero__title {
    font-size: clamp(2.6rem, 6vw, 4.5rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.05;
    color: var(--theme-on-bg);
    margin-bottom: 1.25rem;
  }

  .hero__title em {
    font-style: normal;
    background: linear-gradient(135deg, var(--accent-blue), var(--accent-violet));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero__sub {
    font-size: 1.15rem;
    line-height: 1.65;
    color: var(--theme-on-bg);
    opacity: 0.7;
    margin-bottom: 2rem;
    max-width: 640px;
  }

  .hero__cta {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .btn-hero-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 1.75rem;
    background: var(--theme-on-bg);
    color: var(--theme-bg);
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.95rem;
    transition: var(--theme-transition);
  }

  .btn-hero-primary:hover {
    opacity: 0.85;
    transform: translateY(-1px);
  }

  .btn-hero-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--theme-on-bg);
    opacity: 0.7;
    text-decoration: underline;
    text-underline-offset: 4px;
    transition: var(--theme-transition);
  }

  .btn-hero-secondary:hover {
    opacity: 1;
  }

  /* ═══════════════════════════════════════════
     SERVICES GRID
     ═══════════════════════════════════════════ */

  .bento {
    padding: 5rem 0;
  }

  .bento__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .bento__card {
    border-radius: 16px;
    padding: 1.75rem;
    text-decoration: none;
    color: inherit;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    overflow: hidden;
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .bento__card:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.08);
  }

  .bento__card h3 {
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
  }

  .bento__card p {
    font-size: 0.88rem;
    line-height: 1.6;
    opacity: 0.7;
    flex: 1;
  }

  .bento__card-icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    margin-bottom: 1rem;
    background: rgba(255,255,255,0.5);
  }

  .bento__card-icon svg,
  .bento__card-icon [data-icon] {
    width: 22px;
    height: 22px;
  }

  .bento__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    list-style: none;
    margin-top: 0.85rem;
    padding: 0;
  }

  .bento__tags li {
    padding: 0.2rem 0.55rem;
    background: rgba(255,255,255,0.45);
    border-radius: 6px;
    font-size: 0.72rem;
    font-weight: 600;
    opacity: 0.65;
  }

  /* — Card color variants — */
  .bento__card--eshop {
    background: linear-gradient(145deg, #ecfdf5 0%, #d1fae5 100%);
    color: #064e3b;
  }

  .bento__card--eshop .bento__card-icon {
    color: #059669;
    background: rgba(5, 150, 105, 0.12);
  }

  .bento__card--website {
    background: linear-gradient(145deg, #eff6ff 0%, #dbeafe 100%);
    color: #1e3a5f;
  }

  .bento__card--website .bento__card-icon {
    color: #2563eb;
    background: rgba(37, 99, 235, 0.12);
  }

  .bento__card--seo {
    background: linear-gradient(145deg, #f5f3ff 0%, #ede9fe 100%);
    color: #3b1f6e;
  }

  .bento__card--seo .bento__card-icon {
    color: #7c3aed;
    background: rgba(124, 58, 237, 0.12);
  }

  .bento__card--email {
    background: linear-gradient(145deg, #fffbeb 0%, #fef3c7 100%);
    color: #78350f;
  }

  .bento__card--email .bento__card-icon {
    color: #d97706;
    background: rgba(217, 119, 6, 0.12);
  }

  .bento__card--ads {
    background: linear-gradient(145deg, #fff1f2 0%, #ffe4e6 100%);
    color: #881337;
  }

  .bento__card--ads .bento__card-icon {
    color: #e11d48;
    background: rgba(225, 29, 72, 0.12);
  }

  .bento__card--apps {
    background: linear-gradient(145deg, #f0fdfa 0%, #ccfbf1 100%);
    color: #134e4a;
  }

  .bento__card--apps .bento__card-icon {
    color: #0d9488;
    background: rgba(13, 148, 136, 0.12);
  }

  /* — Stats row — */
  .stats__row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-top: 1rem;
  }

  .stats__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 0.6rem;
    padding: 1.5rem 1.25rem;
