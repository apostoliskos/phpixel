---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import CtaSection from '../components/CtaSection.astro';
import GlassCard from '../components/GlassCard.astro';
import { Icon } from 'astro-icon/components';

const values = [
  {
    icon: 'ic:baseline-psychology',
    title: 'Στρατηγική, όχι μόνο Κώδικας',
    desc: 'Δεν «παραδίδουμε» απλώς μια ιστοσελίδα. Μελετάμε το κοινό σας και χτίζουμε ένα ψηφιακό εργαλείο που φέρνει αποτελέσματα, όχι απλώς clicks.',
    accent: 'var(--accent-violet)',
  },
  {
    icon: 'ic:baseline-handshake',
    title: 'Ειλικρίνεια πάνω από όλα',
    desc: 'Αν κάτι δεν πρόκειται να λειτουργήσει για την επιχείρησή σας, θα σας το πούμε. Προτιμάμε μια ειλικρινή συμβουλή από μια εύκολη πώληση.',
    accent: 'var(--accent-emerald)',
  },
  {
    icon: 'ic:baseline-speed',
    title: 'Performance-First Mindset',
    desc: 'Σε έναν κόσμο που βιάζεται, κάθε millisecond μετράει. Κατασκευάζουμε sites που «πετάνε», βελτιστοποιημένα για ταχύτητα και SEO από την πρώτη γραμμή κώδικα.',
    accent: 'var(--accent-blue)',
  },
  {
    icon: 'ic:baseline-trending-up',
    title: 'Συνεχής Εξέλιξη',
    desc: 'Η τεχνολογία αλλάζει κάθε μέρα. Εμείς μένουμε μπροστά από τις εξελίξεις, για να μην μένετε εσείς πίσω από τον ανταγωνισμό.',
    accent: 'var(--accent-amber)',
  },
];

const steps = [
  {
    num: '01',
    icon: 'ic:baseline-chat',
    title: 'Ανάλυση & Κατανόηση',
    desc: 'Ξεκινάμε με μια δωρεάν συνάντηση για να καταλάβουμε τις ανάγκες σας, τον κλάδο σας και τους στόχους σας. Η σωστή αρχή σημαίνει σωστό αποτέλεσμα.',
  },
  {
    num: '02',
    icon: 'ic:baseline-draw',
    title: 'Σχεδιασμός & Πρόταση',
    desc: 'Ετοιμάζουμε αναλυτική πρόταση με wireframes, χρονοδιάγραμμα και κόστος. Τίποτα δεν αρχίζει χωρίς τη δική σας έγκριση.',
  },
  {
    num: '03',
    icon: 'ic:baseline-code',
    title: 'Development',
    desc: 'Χτίζουμε το project σας με σύγχρονες τεχνολογίες. Regular updates, preview links και ανοιχτή επικοινωνία σε κάθε βήμα.',
  },
  {
    num: '04',
    icon: 'ic:baseline-bug-report',
    title: 'Testing & QA',
    desc: 'Ενδελεχής έλεγχος σε κάθε συσκευή και browser. Performance testing, SEO audit και security check πριν βγούμε live.',
  },
  {
    num: '05',
    icon: 'ic:baseline-rocket-launch',
    title: 'Launch',
    desc: 'Δημοσίευση με μηδέν downtime. Setup analytics, monitoring και ό,τι χρειαστεί για να ξεκινήσετε δυνατά.',
  },
  {
    num: '06',
    icon: 'ic:baseline-support-agent',
    title: 'Ongoing Support',
    desc: 'Δεν σας αφήνουμε μετά το launch. Συνεχής υποστήριξη, updates, backups και βελτιστοποίηση.',
  },
];
---

<BaseLayout
  title="Πώς Δουλεύουμε — Phpixel | Η Διαδικασία μας"
  description="Πώς λειτουργεί η συνεργασία μας: από την πρώτη συζήτηση μέχρι το launch και μετά. Η διαδικασία μας βήμα-βήμα."
>

  <!-- Hero -->
  <section class="hww-hero">
    <div class="hww-hero__bg"></div>
    <div class="container hww-hero__inner">
      <div class="hww-hero__content reveal">
        <span class="hww-badge">Our Process</span>
        <h1>
          Πώς δουλεύουμε<br />
          <span class="accent-text">βήμα-βήμα.</span>
        </h1>
        <p class="hww-hero__sub">
          Η επικοινωνία είναι το Α και το Ω σε μία επιτυχημένη συνεργασία.
          Ορίστε πώς μετατρέπουμε την ιδέα σας σε πραγματικότητα.
        </p>
      </div>
    </div>
  </section>

  <!-- Steps -->
  <section class="hww-steps">
    <div class="container">
      <div class="steps-timeline">
        {steps.map((step, i) => (
          <div class="step reveal" style={`transition-delay: ${i * 0.1}s`}>
            <div class="step__line" aria-hidden="true">
              <div class="step__dot"></div>
            </div>
            <div class="step__content">
              <div class="step__icon">
                <Icon name={step.icon} />
              </div>
              <div class="step__text">
                <span class="step__num">{step.num}</span>
                <h3>{step.title}</h3>
                <p>{step.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Values / Why Us -->
  <section class="hww-values">
    <div class="container">
      <SectionHeader
        eyebrow="Γιατί εμείς"
        title="Τι μας διαφοροποιεί"
        align="center"
      />
      <div class="values-grid">
        {values.map((v, i) => (
          <div class="reveal" style={`transition-delay: ${i * 0.1}s`}>
            <GlassCard
              icon={v.icon}
              title={v.title}
              description={v.desc}
              accent={v.accent}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CtaSection
    title="Έτοιμοι να ξεκινήσουμε;"
    description="Η πρώτη συζήτηση είναι δωρεάν. Πείτε μας για το project σας."
    primaryLabel="Επικοινωνία"
    primaryHref="/contact"
    secondaryLabel="Υπηρεσίες"
    secondaryHref="/services"
  />

</BaseLayout>

<style>
  /* Hero */
  .hww-hero {
    position: relative;
    padding: calc(var(--navbar-height) + 5rem) 0 5rem;
  }

  .hww-hero__bg {
    position: absolute;
    inset: 0;
    background: var(--gradient-subtle);
  }

  .hww-hero__inner { position: relative; }

  .hww-badge {
    display: inline-block;
    padding: 0.35rem 1rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: var(--theme-surface-1);
    border-radius: 2rem;
    margin-bottom: 1.5rem;
  }

  .hww-hero__content h1 { margin-bottom: 1.5rem; }

  .accent-text {
    background: var(--gradient-accent);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hww-hero__sub {
    font-size: 1.15rem;
    line-height: 1.75;
    opacity: 0.7;
    max-width: 520px;
  }

  /* Steps Timeline */
  .hww-steps {
    padding: var(--section-padding);
  }

  .steps-timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
    max-width: 720px;
    margin: 0 auto;
  }

  .step {
    display: flex;
    gap: 2rem;
    position: relative;
  }

  .step__line {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 24px;
    flex-shrink: 0;
    position: relative;
  }

  .step__dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--gradient-accent);
    flex-shrink: 0;
    margin-top: 1.5rem;
    z-index: 1;
  }

  .step__line::after {
    content: '';
    position: absolute;
    top: calc(1.5rem + 14px);
    bottom: 0;
    width: 2px;
    background: rgba(0, 0, 0, 0.08);
  }

  .step:last-child .step__line::after {
    display: none;
  }

  .step__content {
    display: flex;
    gap: 1.25rem;
    padding: 1.5rem 0 3rem;
    flex: 1;
  }

  .step__icon {
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.75rem;
    background: var(--theme-surface-1);
    color: var(--accent-blue);
    flex-shrink: 0;
  }

  .step__icon svg,
  .step__icon [data-icon] {
    width: 26px;
    height: 26px;
  }

  .step__num {
    display: block;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    opacity: 0.4;
    margin-bottom: 0.25rem;
  }

  .step__text h3 {
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
  }

  .step__text p {
    font-size: 0.95rem;
    line-height: 1.7;
    opacity: 0.7;
  }

  /* Values Section */
  .hww-values {
    padding: var(--section-padding);
    background: var(--gradient-subtle);
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--theme-grid-gap, 1.5rem);
    max-width: 960px;
    margin: 3rem auto 0;
  }

  @media (max-width: 768px) {
    .step { gap: 1rem; }
    .step__content { gap: 1rem; }
    .step__icon { width: 44px; height: 44px; }
    .values-grid { grid-template-columns: 1fr; }
  }
</style>
