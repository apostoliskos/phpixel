---
// Στατική σελίδα — μπαίνει στο sitemap και σερβίρεται prerendered
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import PreFooterCta from '../components/PreFooterCta.astro';
import { Icon } from 'astro-icon/components';
import { SHOW_TEAM } from '../config';
import { publicImageExists } from '../utils/publicImages';

const values = [
  {
    icon: 'ic:baseline-speed',
    title: 'Ταχύτητα πρώτα',
    desc: 'Γρήγορο site σημαίνει καλύτερη εμπειρία, καλύτερο SEO και περισσότερες πωλήσεις. Το μετράμε σε κάθε παράδοση.',
  },
  {
    icon: 'ic:baseline-handshake',
    title: 'Ειλικρίνεια',
    desc: 'Αν κάτι δεν πρόκειται να λειτουργήσει για την επιχείρησή σου, θα σου το πούμε. Προτιμάμε μια ειλικρινή συμβουλή από μια εύκολη πώληση.',
  },
  {
    icon: 'ic:baseline-trending-up',
    title: 'Αποτελέσματα, όχι εντυπώσεις',
    desc: 'Δεν φτιάχνουμε «όμορφα» sites που δεν πουλάνε. Κάθε απόφαση κρίνεται από το αν φέρνει πελάτες.',
  },
  {
    icon: 'ic:baseline-support-agent',
    title: 'Δεν εξαφανιζόμαστε',
    desc: 'Η σχέση δεν τελειώνει στο launch. Ενημερώσεις, βελτιώσεις, ένας άνθρωπος που σηκώνει το τηλέφωνο.',
  },
];

const founderImage = '/images/about-founder.webp';
const founderImageExists = publicImageExists(founderImage);
---

<BaseLayout
  title="Ποιοι Είμαστε | phpixel"
  description="Η phpixel είναι μικρή — επίτηδες. Ένας σταθερός υπεύθυνος ανά project, πάνω από δέκα χρόνια στο e-commerce, χωρίς ενδιάμεσους. Μιλάς με αυτόν που φτιάχνει τη δουλειά."
>

  <!-- Hero -->
  <section class="about-hero">
    <div class="about-hero__bg"></div>
    <div class="container about-hero__inner">
      <div class="about-hero__content reveal">
        <span class="about-hero__badge">Σχετικά</span>
        <h1>
          Άνθρωποι,<br />
          <span class="accent-text">όχι τμήματα.</span>
        </h1>
        <p class="about-hero__sub">
          Η phpixel είναι μικρή — επίτηδες. Χωρίς ενδιάμεσους project managers,
          χωρίς tickets. Μιλάς με αυτόν που φτιάχνει τη δουλειά.
        </p>
      </div>
    </div>
  </section>

  <!-- Story -->
  <section class="about-story">
    <div class="container about-story__inner">
      <div class="about-story__text reveal">
        <SectionHeader title="Η Ιστορία μας" subtitle="Πώς ξεκίνησε" align="left" />
        <p>
          Η phpixel ξεκίνησε από έναν άνθρωπο με πάνω από δέκα χρόνια μέσα στο
          e-commerce — πρώτα χτίζοντας και συντηρώντας μεγάλα ηλεκτρονικά καταστήματα
          ως developer, μετά δίπλα σε ελληνικές επιχειρήσεις που ήθελαν να πουλήσουν
          online χωρίς να γίνουν τεχνικοί.
        </p>
        <p>
          Σήμερα δουλεύουμε έτσι: σε κάθε project υπάρχει ένας σταθερός υπεύθυνος —
          ο ίδιος από την πρώτη κουβέντα μέχρι το launch και μετά. Ανάλογα με το τι
          χρειάζεται η δουλειά, μπαίνουν στην ομάδα επιλεγμένοι συνεργάτες: designer,
          marketer, κειμενογράφος. Πληρώνεις για δουλειά, όχι για οργανόγραμμα.
        </p>
      </div>
      <div class="about-story__stats reveal" style="transition-delay: 0.2s">
        <div class="stat-card">
          <span class="stat-card__text">10+ χρόνια στο e-commerce</span>
        </div>
        <div class="stat-card">
          <span class="stat-card__text">Σε όλη την Ελλάδα</span>
        </div>
        <div class="stat-card">
          <span class="stat-card__text">Ένας υπεύθυνος ανά project</span>
        </div>
      </div>
    </div>
  </section>

  {SHOW_TEAM && (
    <!-- Team — ενεργοποιείται με SHOW_TEAM στο src/config.ts -->
    <section class="about-team">
      <div class="container">
        <div class="reveal">
          <SectionHeader title="Η Ομάδα" subtitle="Ποιοι δουλεύουν στο project σου" />
        </div>
        <div class="team-grid">
          <div class="team-card reveal">
            {founderImageExists ? (
              <img
                src={founderImage}
                alt="Ο ιδρυτής της phpixel"
                width="800"
                height="1000"
                loading="lazy"
                decoding="async"
                class="team-card__photo"
              />
            ) : (
              <div class="team-card__photo team-card__photo--placeholder" aria-hidden="true">
                <Icon name="ic:baseline-person" />
              </div>
            )}
            <h3>Αποστόλης Κωστόπουλος — Ιδρυτής</h3>
            <p>10+ χρόνια στο e-commerce</p>
          </div>
          <!-- TODO: συμπλήρωσε τους συνεργάτες πριν ενεργοποιήσεις το SHOW_TEAM -->
          <div class="team-card team-card--todo reveal">
            <div class="team-card__photo team-card__photo--placeholder" aria-hidden="true">
              <Icon name="ic:baseline-person" />
            </div>
            <h3>[Όνομα συνεργάτη]</h3>
            <p>[Ρόλος — π.χ. Designer]</p>
          </div>
          <div class="team-card team-card--todo reveal">
            <div class="team-card__photo team-card__photo--placeholder" aria-hidden="true">
              <Icon name="ic:baseline-person" />
            </div>
            <h3>[Όνομα συνεργάτη]</h3>
            <p>[Ρόλος — π.χ. Marketer]</p>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Values -->
  <section class="about-values">
    <div class="container">
      <div class="reveal">
        <SectionHeader title="Τι Μας Ξεχωρίζει" subtitle="Οι αξίες μας" />
      </div>
      <div class="values-grid">
        {values.map((v, i) => (
          <div class="value-card reveal" style={`transition-delay: ${i * 0.1}s`}>
            <div class="value-card__icon">
              <Icon name={v.icon} />
            </div>
            <h3>{v.title}</h3>
            <p>{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <PreFooterCta />

</BaseLayout>

<style>
  /* Hero */
  .about-hero {
    position: relative;
    padding: calc(var(--navbar-height) + 5rem) 0 5rem;
  }

  .about-hero__bg {
    position: absolute;
    inset: 0;
    background: var(--gradient-subtle);
  }

  .about-hero__inner {
    position: relative;
  }

  .about-hero__badge {
    display: inline-block;
    padding: 0.35rem 1rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: var(--theme-surface-1);
    border-radius: 2rem;
    margin-bottom: 1.5rem;
  }

  .about-hero__content h1 {
    margin-bottom: 1.5rem;
  }

  .accent-text {
    background: var(--gradient-accent);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .about-hero__sub {
    font-size: 1.15rem;
    line-height: 1.75;
    opacity: 0.7;
    max-width: 560px;
  }

  /* Story */
  .about-story {
    padding: var(--section-padding);
  }

  .about-story__inner {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .about-story__text p {
    font-size: 1.05rem;
    line-height: 1.8;
    opacity: 0.7;
    margin-bottom: 1rem;
  }

  .about-story__stats {
    display: grid;
    gap: 1rem;
  }

  .stat-card {
    padding: 1.75rem 2rem;
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: var(--theme-shape-radius);
    text-align: center;
  }

  .stat-card__text {
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  /* Team */
  .about-team {
    padding: var(--section-padding);
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    max-width: 960px;
    margin: 0 auto;
  }

  .team-card {
    text-align: center;
  }

  .team-card__photo {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: var(--theme-shape-radius);
    margin-bottom: 1rem;
  }

  .team-card__photo--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--theme-surface-2) 0%, var(--theme-surface-1) 100%);
  }

  .team-card__photo--placeholder svg,
  .team-card__photo--placeholder [data-icon] {
    width: 48px;
    height: 48px;
    opacity: 0.2;
  }

  .team-card h3 {
    font-size: 1.05rem;
    margin-bottom: 0.25rem;
  }

  .team-card p {
    font-size: 0.9rem;
    opacity: 0.6;
  }

  .team-card--todo {
    opacity: 0.55;
  }

  /* Values */
  .about-values {
    padding: var(--section-padding);
    background: var(--theme-surface-1);
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .value-card {
    padding: 2rem;
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: var(--theme-shape-radius);
    transition: var(--theme-transition);
  }

  .value-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.08);
  }

  .value-card__icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.75rem;
    background: color-mix(in srgb, var(--accent-blue) 10%, transparent);
    color: var(--accent-blue);
    margin-bottom: 1.25rem;
  }

  .value-card__icon svg,
  .value-card__icon [data-icon] {
    width: 24px;
    height: 24px;
  }

  .value-card h3 {
    font-size: 1.1rem;
    margin-bottom: 0.75rem;
  }

  .value-card p {
    font-size: 0.9rem;
    line-height: 1.65;
    opacity: 0.7;
  }

  @media (max-width: 768px) {
    .about-story__inner { grid-template-columns: 1fr; gap: 2rem; }
    .about-story__stats { grid-template-columns: 1fr; }
    .values-grid { grid-template-columns: 1fr 1fr; }
    .team-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 480px) {
    .values-grid { grid-template-columns: 1fr; }
  }
</style>
