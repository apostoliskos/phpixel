---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { generateSlug, generateTagData } from '../../../utils/helpers.js';

const { slug } = Astro.params;

const postModules = import.meta.glob('../posts/*.mdx', { eager: true });
const allPosts = Object.values(postModules) as any[];
const sortedPosts = allPosts.sort(
  (a, b) => new Date(b.frontmatter.date).valueOf() - new Date(a.frontmatter.date).valueOf()
);

// Find the tag title that matches this slug
let tag = slug;
for (const post of sortedPosts) {
  if (post.frontmatter.tags) {
    const match = post.frontmatter.tags.find((t) => generateSlug(t) === slug);
    if (match) {
      tag = match;
      break;
    }
  }
}

// Filter posts that have this tag
const posts = sortedPosts.filter(
  (post) => post.frontmatter.tags && post.frontmatter.tags.some((t) => generateSlug(t) === slug)
);

// 404 if no posts found for this tag
if (posts.length === 0) {
  return Astro.redirect('/blog');
}
---

<BaseLayout
  title={`${tag} — Phpixel Blog`}
  description={`Άρθρα με tag "${tag}" από το blog της Phpixel.`}
>

  <section class="tag-page">
    <div class="tag-page__bg"></div>
    <div class="container tag-page__inner">
      <div class="reveal">
        <a href="/blog" class="tag-page__back">&larr; Πίσω στο Blog</a>
        <span class="tag-page__badge">{tag}</span>
        <h1>Άρθρα: {tag}</h1>
        <p class="tag-page__count">{posts.length} {posts.length === 1 ? 'άρθρο' : 'άρθρα'}</p>
      </div>
    </div>
  </section>

  <section class="tag-posts">
    <div class="container">
      <ul class="tag-posts__list">
        {posts.map((post) => (
          <li class="tag-post reveal">
            <a href={post.url} class="tag-post__link">
              {post.frontmatter.featuredImage && (
                <img
                  src={post.frontmatter.featuredImage}
                  alt={post.frontmatter.title}
                  class="tag-post__img"
                  loading="lazy"
                />
              )}
              <div class="tag-post__text">
                <h3>{post.frontmatter.title}</h3>
                {post.frontmatter.excerpt && (
                  <p>{post.frontmatter.excerpt}</p>
                )}
              </div>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

</BaseLayout>

<style>
  .tag-page {
    position: relative;
    padding: calc(var(--navbar-height) + 3rem) 0 2rem;
  }

  .tag-page__bg {
    position: absolute;
    inset: 0;
    background: var(--gradient-subtle);
  }

  .tag-page__inner {
    position: relative;
  }

  .tag-page__back {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 600;
    opacity: 0.6;
    margin-bottom: 1rem;
    transition: var(--theme-transition);
  }

  .tag-page__back:hover {
    opacity: 1;
    color: var(--accent-blue);
  }

  .tag-page__badge {
    display: inline-block;
    padding: 0.35rem 1rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border: 1px solid var(--accent-blue);
    color: var(--accent-blue);
    border-radius: 2rem;
    margin-bottom: 1rem;
  }

  .tag-page__count {
    font-size: 1rem;
    opacity: 0.5;
    margin-top: 0.5rem;
  }

  .tag-posts {
    padding: 2rem 0 var(--section-margin);
  }

  .tag-posts__list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .tag-post {
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: var(--theme-shape-radius);
    overflow: hidden;
    transition: var(--theme-transition);
  }

  .tag-post:hover {
    transform: translateX(4px);
    border-color: var(--accent-blue);
  }

  .tag-post__link {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.25rem;
    text-decoration: none;
    color: inherit;
  }

  .tag-post__img {
    width: 120px;
    height: 80px;
    object-fit: cover;
    border-radius: var(--theme-shape-radius-sm);
    flex-shrink: 0;
  }

  .tag-post__text h3 {
    font-size: 1.1rem;
    margin-bottom: 0.35rem;
  }

  .tag-post__text p {
    font-size: 0.9rem;
    opacity: 0.6;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 768px) {
    .tag-post__link { flex-direction: column; gap: 1rem; }
    .tag-post__img { width: 100%; height: 160px; }
  }
</style>
