---
import { parse, isBefore, isValid } from 'date-fns';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogPostsList from '../../components/blog/BlogPostsList.astro';

function parseFlexibleDate(dateStr: string): Date {
  // Try ISO format first (2025-12-12)
  const isoDate = new Date(dateStr);
  if (isValid(isoDate) && !isNaN(isoDate.getTime())) return isoDate;
  // Then try "MMMM d, yyyy"
  const parsed = parse(dateStr, 'MMMM d, yyyy', new Date());
  if (isValid(parsed)) return parsed;
  // Fallback
  return new Date();
}

const posts = await Astro.glob('./posts/*.mdx').then(posts =>
  posts
    .map(({ frontmatter, url }) => ({
      title: frontmatter.title,
      description: frontmatter.description,
      authors: frontmatter.authors,
      publishDate: parseFlexibleDate(frontmatter.publishDate),
      featuredImage: frontmatter.featuredImage,
      excerpt: frontmatter.excerpt,
      href: url,
    }))
    .sort((a, b) => {
      if (isBefore(a.publishDate, b.publishDate)) return 1;
      if (isBefore(b.publishDate, a.publishDate)) return -1;
      return 0;
    })
);
---

<BaseLayout
  title="Blog — Phpixel | Άρθρα & Νέα"
  description="Άρθρα για web development, e-commerce, SEO, UX/UI design και digital marketing από την Phpixel."
>

  <!-- Hero -->
  <section class="blog-hero">
    <div class="blog-hero__bg"></div>
    <div class="container blog-hero__inner">
      <div class="reveal">
        <span class="blog-badge">Blog</span>
        <h1>Άρθρα & Insights</h1>
        <p class="blog-hero__sub">
          Χρήσιμα άρθρα για web development, e-commerce, SEO και digital marketing.
        </p>
      </div>
    </div>
  </section>

  <!-- Posts Grid -->
  <section class="blog-section">
    <div class="container">
      {posts.length > 0 ? (
        <BlogPostsList posts={posts} />
      ) : (
        <div class="blog-empty reveal">
          <p>Δεν υπάρχουν ακόμα δημοσιεύσεις. Μείνετε συντονισμένοι!</p>
        </div>
      )}
    </div>
  </section>

</BaseLayout>

<style>
  .blog-hero {
    position: relative;
    padding: calc(var(--navbar-height) + 4rem) 0 3rem;
  }

  .blog-hero__bg {
    position: absolute;
    inset: 0;
    background: var(--gradient-subtle);
  }

  .blog-hero__inner {
    position: relative;
  }

  .blog-badge {
    display: inline-block;
    padding: 0.35rem 1rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: var(--theme-surface-1);
    border-radius: 2rem;
    margin-bottom: 1.5rem;
  }

  .blog-hero__sub {
    font-size: 1.1rem;
    line-height: 1.7;
    opacity: 0.65;
    max-width: 500px;
    margin-top: 1rem;
  }

  .blog-section {
    padding: 3rem 0 var(--section-margin);
  }

  .blog-empty {
    text-align: center;
    padding: 4rem 0;
    opacity: 0.5;
    font-size: 1.1rem;
  }
</style>
