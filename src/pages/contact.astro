---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/forms/ContactForm.astro';
import { Icon } from 'astro-icon/components';
import { site } from '../data/site';
---

<BaseLayout
  title="Επικοινωνία — Phpixel | Μίλησέ μας"
  description="Επικοινωνήστε με την Phpixel. Πες μας για το project σου και θα σου απαντήσουμε εντός 24 ωρών."
>

  <section class="contact-page">
    <div class="contact-page__bg"></div>
    <div class="container contact-page__inner">

      <!-- Left: Info -->
      <div class="contact-info reveal">
        <span class="contact-badge">Επικοινωνία</span>
        <h1>Μίλησέ μας</h1>
        <p class="contact-info__sub">
          Μην διστάσεις να στείλεις μήνυμα. Θα απαντήσουμε εντός 24 ωρών.
        </p>

        <div class="contact-details">
          <a href={`tel:${site.contact.phone}`} class="contact-detail">
            <div class="contact-detail__icon">
              <Icon name="ic:baseline-phone" />
            </div>
            <div>
              <span class="contact-detail__label">Τηλέφωνο</span>
              <span class="contact-detail__value">{site.contact.phone}</span>
            </div>
          </a>

          <a href={`mailto:${site.contact.email}`} class="contact-detail">
            <div class="contact-detail__icon">
              <Icon name="ic:baseline-mail" />
            </div>
            <div>
              <span class="contact-detail__label">Email</span>
              <span class="contact-detail__value">{site.contact.email}</span>
            </div>
          </a>

          <div class="contact-detail">
            <div class="contact-detail__icon">
              <Icon name="ic:baseline-location-on" />
            </div>
            <div>
              <span class="contact-detail__label">Τοποθεσία</span>
              <span class="contact-detail__value">{site.contact.address}</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Form -->
      <div class="contact-form-wrapper reveal" style="transition-delay: 0.2s">
        <div class="contact-form-card">
          <ContactForm />
        </div>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  .contact-page {
    position: relative;
    padding: calc(var(--navbar-height) + 4rem) 0 6rem;
    min-height: 100vh;
  }

  .contact-page__bg {
    position: absolute;
    inset: 0;
    background: var(--gradient-subtle);
  }

  .contact-page__inner {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .contact-badge {
    display: inline-block;
    padding: 0.35rem 1rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: var(--theme-surface-1);
    border-radius: 2rem;
    margin-bottom: 1.5rem;
  }

  .contact-info h1 {
    margin-bottom: 1rem;
  }

  .contact-info__sub {
    font-size: 1.1rem;
    line-height: 1.7;
    opacity: 0.7;
    margin-bottom: 2.5rem;
    max-width: 400px;
  }

  .contact-details {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact-detail {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: var(--theme-shape-radius-sm);
    transition: var(--theme-transition);
    text-decoration: none;
    color: inherit;
  }

  a.contact-detail:hover {
    transform: translateX(4px);
    border-color: var(--accent-blue);
  }

  .contact-detail__icon {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.75rem;
    background: color-mix(in srgb, var(--accent-blue) 10%, transparent);
    color: var(--accent-blue);
    flex-shrink: 0;
  }

  .contact-detail__icon svg,
  .contact-detail__icon [data-icon] {
    width: 22px;
    height: 22px;
  }

  .contact-detail__label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    opacity: 0.5;
    margin-bottom: 0.15rem;
  }

  .contact-detail__value {
    display: block;
    font-weight: 600;
    font-size: 0.95rem;
  }

  .contact-form-card {
    padding: 2.5rem;
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: var(--theme-shape-radius);
    box-shadow: var(--glass-shadow);
  }

  @media (max-width: 768px) {
    .contact-page__inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
